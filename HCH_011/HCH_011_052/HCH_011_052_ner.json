        "text": "吳郡吳",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_052_000015",
    "sentence": "祖抃之，宋鎮軍將軍、湘州刺史。",
    "entities": [
      {
        "text": "祖抃之",
        "label": "PER"
      },
      {
        "text": "宋",
        "label": "ORG"
      },
      {
