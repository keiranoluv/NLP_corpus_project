      }
    ]
  },
  {
    "sentence_id": "HCH_011_052_000011",
    "sentence": "《宋書·止足傳》有羊欣、王微，咸其流亞。",
    "entities": [
      {
        "text": "《宋書·止足傳》",
        "label": "ORG"
      },
      {
        "text": "羊欣",
