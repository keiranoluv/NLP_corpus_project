      }
    ]
  },
  {
    "sentence_id": "HCH_011_055_000010",
    "sentence": "及淑媛寵衰怨望，遂陳疑似之說，故綜懷之。",
    "entities": [
      {
        "text": "淑媛",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_055_000011",
    "sentence": "旣長，有才學，善屬文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_055_000012",
    "sentence": "高祖御諸子以禮，朝見不甚數，綜恒怨不見知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_055_000013",
    "sentence": "每出籓，淑媛恒隨之鎮。",
    "entities": [
      {
        "text": "淑媛",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_055_000014",
    "sentence": "至年十五六，尚躶袒嬉戲於前，晝夜無別，內外咸有穢議。",
    "entities": [
      {
        "text": "年十五六",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_055_000015",
    "sentence": "綜在徐州，政刑酷暴。",
