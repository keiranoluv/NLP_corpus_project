  },
  {
    "sentence_id": "HCH_011_055_000016",
    "sentence": "又有勇力，手制奔馬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_055_000017",
    "sentence": "常微行夜出，無有期度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_055_000018",
    "sentence": "每高祖有敕疏至，輒忿恚形於顏色，羣臣莫敢言者。",
