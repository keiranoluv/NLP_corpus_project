        "text": "皇太子",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_058_000141",
    "sentence": "百官于思善門外行禮如儀。",
    "entities": [
      {
        "text": "思善門",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_058_000142",
    "sentence": "明日，百官行奉慰禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_058_000143",
    "sentence": "卒哭用虞祭後剛日，禮同虞祭，自是罷朝夕奠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_058_000144",
    "sentence": "祔饗用卒哭之明日，太常寺設醴饌於太廟，如時饗儀，樂設而不作。",
    "entities": [
      {
