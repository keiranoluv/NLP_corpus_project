        "text": "皇后",
        "label": "TITLE"
      },
      {
        "text": "王府",
        "label": "LOC"
      },
      {
        "text": "在京文武官",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_058_000162",
    "sentence": "自神主出几筵殿，內侍即撤几筵、帷幄，焚于思善門外。",
    "entities": [
      {
        "text": "思善門",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_058_000163",
    "sentence": "禫祭，遣親王詣陵行禮。",
    "entities": [
      {
        "text": "禫祭",
        "label": "TME"
      },
      {
        "text": "親王",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_058_000164",
    "sentence": "洪熙元年，仁宗崩。",
