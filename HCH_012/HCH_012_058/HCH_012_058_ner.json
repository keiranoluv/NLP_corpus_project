    "sentence": "禫祭後，始釋素服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_058_000192",
    "sentence": "從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_058_000193",
