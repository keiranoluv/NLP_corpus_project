      }
    ]
  },
  {
    "sentence_id": "HCH_012_058_000172",
    "sentence": "宮中自皇后以下皆披髮哭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_058_000173",
    "sentence": "皇太子就喪次東，見母后。",
