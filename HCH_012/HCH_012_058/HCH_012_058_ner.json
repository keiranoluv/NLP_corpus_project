        "text": "皇太子",
        "label": "TITLE"
      },
      {
        "text": "盧溝橋",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_058_000169",
    "sentence": "皇太子至，常服，詣次四拜。",
    "entities": [
      {
        "text": "皇太子",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_058_000170",
    "sentence": "聽宣遺詔，復四拜，哭盡哀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_058_000171",
    "sentence": "易素服至長安右門下馬，步哭至宮門外，釋冠服，披髮詣梓宮前，五拜三叩首，哭盡哀。",
    "entities": [
