      {
        "text": "皇太子",
        "label": "TITLE"
      },
      {
        "text": "南京",
        "label": "LOC"
      },
      {
        "text": "良鄉",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_058_000166",
    "sentence": "文武官常服於午門外四拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_058_000167",
    "sentence": "宣畢，舉哀，復四拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_058_000168",
    "sentence": "易素服，迎皇太子於盧溝橋，橋南設幕次香案。",
