  },
  {
    "sentence_id": "HCH_012_032_000093",
    "sentence": "舊法以一百一度相減乘。",
    "entities": [
      {
        "text": "一百一度",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_032_000094",
    "sentence": "《授時》立術，以句股、弧矢、方圓、斜直所容，求其數差，合於渾象之理，視古爲密。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000095",
    "sentence": "顧《至元曆經》所載略，又誤以黃道矢度爲積差，黃道矢差爲率，今正之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000096",
    "sentence": "凡渾圓中剖，則成平圓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000097",
    "sentence": "任割平圓之一分，成弧矢形，皆有弧背，有弧弦，有矢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000098",
    "sentence": "剖弧矢形而半之，則有半弧背，有半弧弦，有矢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000099",
    "sentence": "因弦矢句股形，以半弧弦爲句，矢減半徑之餘爲股，半徑爲弦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000100",
    "sentence": "句股內成小句股，則有小句、小股、小弦、而大小可互求，平側可互用，渾圓之理，斯爲密近。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000101",
    "sentence": "平者爲赤道，斜者爲黃道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000102",
    "sentence": "因二至黃道赤之距，生大句股。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000103",
    "sentence": "因各度黃赤之距，生小句股。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000104",
    "sentence": "外大圓爲赤道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000105",
    "sentence": "從北極平視，則黃道在赤道內，有赤道各度，即各有其半弧弦，以生大名股。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000106",
    "sentence": "又各有其相當之黃道半弧弦，以生小句股。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000107",
    "sentence": "此二者皆可互求。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000108",
    "sentence": "按舊史無圖，然表亦圖之屬也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000109",
    "sentence": "今句股割弧矢之法，實爲歷家測算之本。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000110",
    "sentence": "非圖不明，因存其要者數端。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000111",
    "sentence": "推黃道各度，距赤道內外及去極遠近術。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000112",
    "sentence": "置半徑內減去赤道小弦，餘爲赤道二絃差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000113",
    "sentence": "又爲黃赤道小弧矢，又爲內外矢，又爲股弦差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000114",
    "sentence": "置半徑內外減去黃道矢度，餘爲黃赤道小弦，以二至黃赤道內外半弧弦乘之爲實，以黃赤道大弦爲法，即半徑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000115",
    "sentence": "除之爲黃赤道小弧弦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000116",
    "sentence": "即黃赤道內外半弧弦，又爲黃赤道小句。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000117",
    "sentence": "置黃赤道小弧矢自之，即赤道二絃差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_032_000118",
    "sentence": "以全徑除之，爲半背弦差。",
    "entities": []
  },
  {
