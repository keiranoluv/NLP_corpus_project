      }
    ]
  },
  {
    "sentence_id": "HCH_012_109_000007",
    "sentence": "其時章疏直達御前，多出辰斷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_109_000008",
    "sentence": "儒臣入直，備顧問而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_109_000009",
    "sentence": "至仁宗而後，諸大學士歷晉尚書、保、傅，品位尊崇，地居近密，而綸言批答，裁決機宜，悉由票擬，閣權之重偃然漢、唐宰輔，特不居丞相名耳。",
    "entities": [
