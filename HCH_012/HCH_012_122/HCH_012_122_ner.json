      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000048",
    "sentence": "太祖曰：「德崖嘗困公，宜為備。」",
    "entities": [
      {
        "text": "太祖",
        "label": "TITLE"
      },
      {
        "text": "德崖",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000049",
    "sentence": "子興默然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_122_000050",
