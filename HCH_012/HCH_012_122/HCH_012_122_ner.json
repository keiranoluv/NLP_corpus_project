      {
        "text": "德崖",
        "label": "PER"
      },
      {
        "text": "子興",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000052",
    "sentence": "子興執德崖，太祖亦為德崖軍所執。",
