        "label": "LOC"
      },
      {
        "text": "子興",
        "label": "PER"
      },
      {
        "text": "太祖",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000045",
    "sentence": "德崖饑，就食和境，求駐軍城中，太祖納之。",
    "entities": [
      {
        "text": "德崖",
        "label": "PER"
      },
      {
        "text": "和境",
        "label": "LOC"
      },
      {
        "text": "太祖",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000046",
    "sentence": "有讒於子興者。",
