[
  {
    "sentence_id": "HCH_012_122_000001",
    "sentence": "郭子興，其先曹州人。",
    "entities": [
      {
        "text": "郭子興",
        "label": "PER"
      },
      {
        "text": "曹州",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000002",
    "sentence": "父郭公，少以日者術遊定遠，言禍福輒中。",
    "entities": [
      {
        "text": "定遠",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000003",
    "sentence": "邑富人有瞽女無所歸，郭公乃娶之，家日益饒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_122_000004",
    "sentence": "生三子，子興其仲出。",
    "entities": [
      {
        "text": "仲",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000005",
    "sentence": "始生，郭公卜之吉。",
    "entities": [
      {
        "text": "郭公",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000006",
    "sentence": "及長，任俠，喜賓客。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_122_000007",
    "sentence": "會元政亂，子興散家資，椎牛釃酒，與壯士結納。",
    "entities": [
      {
        "text": "子興",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000008",
    "sentence": "至正十二年春，集少年數千人，襲據濠州。",
    "entities": [
      {
        "text": "至正十二年春",
        "label": "TME"
      },
      {
        "text": "年數千",
        "label": "NUM"
      },
      {
        "text": "濠州",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000009",
    "sentence": "太祖往從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_122_000010",
    "sentence": "門者疑其諜，執以告子興。",
    "entities": [
      {
        "text": "子興",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000011",
    "sentence": "子興奇太祖狀貌，解縛與語，收帳下。",
    "entities": [
      {
        "text": "子興",
        "label": "PER"
      },
      {
        "text": "太祖",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000012",
    "sentence": "為十夫長，數從戰有功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_122_000013",
    "sentence": "子興喜，其次妻小張夫人亦指目太祖曰：「此異人也。」",
    "entities": [
      {
        "text": "子興",
        "label": "PER"
      },
      {
        "text": "小張夫人",
        "label": "TITLE"
      },
      {
        "text": "太祖",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000014",
    "sentence": "乃妻以所撫馬公女，是為孝慈高皇后。",
    "entities": [
      {
        "text": "馬公",
        "label": "TITLE"
      },
      {
        "text": "孝慈高皇后",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000015",
    "sentence": "始，子興同起事者孫德崖等四人，與子興而五，各稱元帥不相下。",
    "entities": [
      {
        "text": "子興",
        "label": "PER"
      },
      {
        "text": "孫德崖",
        "label": "PER"
      },
      {
        "text": "四人",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000016",
    "sentence": "四人者粗而戇，日剽掠，子興意輕之。",
    "entities": [
      {
        "text": "四人",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000017",
    "sentence": "四人不悅，合謀傾子興。",
    "entities": [
      {
        "text": "四人",
        "label": "NUM"
      },
      {
        "text": "子興",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000018",
    "sentence": "子興以是多家居不視事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_122_000019",
    "sentence": "太祖乘閑說曰：「彼日益合，我益離，久之必為所制。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_122_000020",
    "sentence": "子興不能從也。",
    "entities": [
      {
        "text": "子興",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000021",
    "sentence": "元師破徐州，徐帥彭大、趙均用帥餘眾奔濠。",
    "entities": [
      {
        "text": "元師",
        "label": "ORG"
      },
      {
        "text": "徐州",
        "label": "LOC"
      },
      {
        "text": "徐帥",
        "label": "TITLE"
      },
      {
        "text": "彭大",
        "label": "PER"
      },
      {
        "text": "趙均用",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000022",
    "sentence": "德崖等以其故盜魁有名，乃共推奉之，使居己上。",
    "entities": [
      {
        "text": "德崖",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000023",
    "sentence": "大有智數，子興與相厚而薄均用。",
    "entities": [
      {
        "text": "子興",
        "label": "PER"
      },
      {
        "text": "均用",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000024",
    "sentence": "於是德崖等譖諸均用曰：「子興知有彭將軍耳，不知有將軍也。」",
    "entities": [
      {
        "text": "德崖",
        "label": "PER"
      },
      {
        "text": "均用",
        "label": "PER"
      },
      {
        "text": "子興",
        "label": "PER"
      },
      {
        "text": "彭將軍",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000025",
    "sentence": "均用怒，乘間執子興，幽諸德崖家。",
    "entities": [
      {
        "text": "均用",
        "label": "PER"
      },
      {
        "text": "子興",
        "label": "PER"
      },
      {
        "text": "德崖",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000026",
    "sentence": "太祖自他部歸，大驚，急帥子興二子訴於大。",
    "entities": [
      {
        "text": "太祖",
        "label": "TITLE"
      },
      {
        "text": "大",
        "label": "PER"
      },
      {
        "text": "子興",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000027",
    "sentence": "大曰：「吾在，孰敢魚肉而翁者！」",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_122_000028",
    "sentence": "與太祖偕詣德崖家，破械出子興，挾之歸。",
    "entities": [
      {
        "text": "太祖",
        "label": "TITLE"
      },
      {
        "text": "德崖",
        "label": "PER"
      },
      {
        "text": "子興",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000029",
    "sentence": "元師圍濠州，乃釋故憾，共城守五閱月。",
    "entities": [
      {
        "text": "濠州",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000030",
    "sentence": "圍解，大、均用皆自稱王，而子興及德崖等為元帥如故。",
    "entities": [
      {
        "text": "大",
        "label": "PER"
      },
      {
        "text": "均用",
        "label": "PER"
      },
      {
        "text": "子興",
        "label": "PER"
      },
      {
        "text": "德崖",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000031",
    "sentence": "未幾，大死，子早住領其眾。",
    "entities": [
      {
        "text": "大",
        "label": "PER"
      },
      {
        "text": "早住",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_122_000032",
    "sentence": "均用專狠益甚，挾子興攻盱眙、泗州，將害之。",
    "entities": [
      {
        "text": "均用",
        "label": "PER"
      },
      {
        "text": "子興",
        "label": "PER"
      },
      {
        "text": "盱眙",
