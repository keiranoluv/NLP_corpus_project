    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000102",
    "sentence": "早孤，絕意科舉，求古聖賢禔躬訓家之法，率而行之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000103",
