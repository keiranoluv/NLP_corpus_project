        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000067",
    "sentence": "宋濂之為學士也，擬薦為國子師，聞不受州郡辟命，乃已。",
    "entities": [
      {
        "text": "宋濂",
        "label": "PER"
      },
      {
        "text": "學士",
        "label": "TITLE"
      },
      {
