        "text": "白鹿生",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000062",
    "sentence": "太祖既下浙東，命欒鳳知州事。",
    "entities": [
      {
        "text": "太祖",
        "label": "TITLE"
      },
      {
        "text": "欒鳳",
        "label": "PER"
      },
      {
        "text": "知州事",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000063",
    "sentence": "鳳請為州學師，恆固讓不起。",
    "entities": [
      {
        "text": "鳳",
        "label": "PER"
      },
      {
        "text": "州學師",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000064",
    "sentence": "鳳乃命州中子弟即家問道。",
    "entities": [
      {
        "text": "州",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000065",
    "sentence": "政有缺失，輒貽書咨訪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000066",
    "sentence": "後唐鐸知紹興，欲辟起之，復固辭。",
