      {
        "text": "家",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000058",
    "sentence": "楊恆，字本初，諸暨人。",
    "entities": [
      {
        "text": "楊恆",
        "label": "PER"
      },
      {
        "text": "本初",
        "label": "PER"
      },
      {
        "text": "諸暨",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000059",
    "sentence": "外族方氏建義塾，館四方游學士，恆幼往受諸經，輒領其旨要。",
    "entities": [
      {
        "text": "方氏",
        "label": "ORG"
      },
      {
        "text": "義塾",
        "label": "ORG"
      },
      {
        "text": "四方游學士",
        "label": "ORG"
      },
      {
        "text": "恆",
        "label": "PER"
      },
      {
        "text": "諸經",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000060",
    "sentence": "文峻潔，有聲郡邑間。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000061",
    "sentence": "浦江鄭氏延為師，閱十年退居白鹿山，戴棕冠，披羊裘，帶經耕煙雨間，嘯歌自樂，因自號白鹿生。",
    "entities": [
      {
        "text": "浦江",
        "label": "LOC"
      },
      {
        "text": "鄭氏",
