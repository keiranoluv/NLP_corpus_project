      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000068",
    "sentence": "恆性醇篤，與人語，出肺肝相示。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000069",
    "sentence": "事稍乖名義，輒峻言指斥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000070",
    "sentence": "家無儋石，而臨財甚介，鄉人奉為楷法焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000071",
    "sentence": "時有陳洄者，義烏人。",
    "entities": [
      {
        "text": "陳洄",
        "label": "PER"
      },
      {
        "text": "義烏",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000072",
    "sentence": "幼治經，長通百家言。",
    "entities": [
      {
        "text": "百家",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000073",
    "sentence": "初欲以功名顯，既而隱居，戴青霞冠，披白鹿裘，不復與塵事接。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000074",
    "sentence": "所居近大溪，多修竹，自號竹溪逸民。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000075",
    "sentence": "常乘小艇，吹短簫，吹已，叩舷而歌，悠然自適。",
    "entities": []
  },
