[
  {
    "sentence_id": "HCH_012_298_000001",
    "sentence": "韓愈言：「《蹇》之六二曰『王臣蹇蹇』，而《蠱》之上九曰『高尚其事』，由所居之時不一，而所蹈之德不同。」",
    "entities": [
      {
        "text": "韓愈",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000002",
    "sentence": "夫聖賢以用世為心，而逸民以肥遁為節，豈性分實然，亦各行其志而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000003",
    "sentence": "明太祖興禮儒士，聘文學，搜求岩穴，側席幽人，後置不為君用之罰，然韜跡自遠者，亦不乏人。",
    "entities": [
      {
        "text": "明太祖",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000004",
    "sentence": "迨中葉承平，聲教淪浹，巍科顯爵，頓天網以羅英俊，民之秀者，無不觀國光而賓王廷矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000005",
    "sentence": "其抱瑰材，蘊積學，槁形泉石，絕意當世者，靡得而稱焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000006",
    "sentence": "由是觀之，世道升降之端，系所遭逢，豈非其時為之哉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000007",
    "sentence": "凡徵聘所及，文學行誼可稱者，已散見諸傳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000008",
    "sentence": "茲取貞節超邁者數人，作《隱逸傳》。",
    "entities": [
      {
        "text": "數人",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000009",
    "sentence": "張介福，字子祺，自懷慶徙吳中。",
    "entities": [
      {
        "text": "張介福",
        "label": "PER"
      },
      {
        "text": "子祺",
        "label": "PER"
      },
      {
        "text": "懷慶",
        "label": "LOC"
      },
      {
        "text": "吳中",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000010",
    "sentence": "少受學於許衡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000011",
    "sentence": "二親早終，遂無仕進意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000012",
    "sentence": "家貧，冬不能具夾襦，或遺以糹寧絮，不受，纖介必以禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000013",
    "sentence": "張士誠入吳，有卒犯其家，危坐不為起。",
    "entities": [
      {
        "text": "張士誠",
        "label": "PER"
      },
      {
        "text": "吳",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000014",
    "sentence": "刀斫面，僕地，醒復取冠戴之，坐自若。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000015",
    "sentence": "卒怪，以為異物，走去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000016",
    "sentence": "介福恐發其先墓，往廬焉。",
    "entities": [
      {
        "text": "介福",
        "label": "PER"
      },
      {
        "text": "廬",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000017",
    "sentence": "士誠聞而欲致之，不可。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000018",
    "sentence": "使其弟往問，答曰：「無樂亂，無貪天禍，無忘國家。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000019",
    "sentence": "饋之，力辭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000020",
    "sentence": "已，病革，謂其友曰：「吾志希古人，未能也。惟無污於時，庶幾哉。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000021",
    "sentence": "遂卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000022",
    "sentence": "倪瓚，字元鎮，無錫人也。",
    "entities": [
      {
        "text": "倪瓚",
        "label": "PER"
      },
      {
        "text": "元鎮",
        "label": "PER"
      },
      {
        "text": "無錫",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000023",
    "sentence": "家雄於貲，工詩，善書畫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000024",
    "sentence": "四方名士日至其門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000025",
    "sentence": "所居有閣曰清閟，幽迥絕塵。",
    "entities": [
      {
        "text": "清閟",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000026",
    "sentence": "藏書數千卷，皆手自勘定。",
    "entities": [
      {
        "text": "數千卷",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000027",
    "sentence": "古鼎法書，名琴奇畫，陳列左右。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000028",
    "sentence": "四時卉木，縈繞其外，高木修篁，蔚然深秀，故自號雲林居士。",
    "entities": [
      {
        "text": "四時",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000029",
    "sentence": "時與客觴詠其中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000030",
    "sentence": "為人有潔癖，盥濯不離手。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000031",
    "sentence": "俗客造廬，比去，必洗滌其處。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000032",
    "sentence": "求縑素者踵至，瓚亦時應之。",
    "entities": [
      {
        "text": "縑素",
        "label": "NUM"
      },
      {
        "text": "瓚",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000033",
    "sentence": "至正初，海內無事，忽散其貲給親故，人咸怪之。",
    "entities": [
      {
        "text": "至正",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000034",
    "sentence": "未幾兵興，富家悉被禍，而瓚扁舟箬笠，往來震澤、三泖間，獨不罹患。",
    "entities": [
      {
        "text": "未幾",
        "label": "TME"
      },
      {
        "text": "兵興",
        "label": "TME"
      },
      {
        "text": "瓚",
        "label": "PER"
      },
      {
        "text": "震澤",
        "label": "LOC"
      },
      {
        "text": "三泖",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000035",
    "sentence": "張士誠累欲鉤致之，逃漁舟以免。",
    "entities": [
      {
        "text": "張士誠",
        "label": "PER"
      },
      {
        "text": "漁舟",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000036",
    "sentence": "其弟士信以幣乞畫，瓚又斥去。",
    "entities": [
      {
        "text": "士信",
        "label": "PER"
      },
      {
        "text": "瓚",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000037",
    "sentence": "士信恚，他日從賓客游湖上，聞異香出葭葦間，疑為瓚也，物色漁舟中，果得之。",
    "entities": [
      {
        "text": "士信",
        "label": "PER"
      },
      {
        "text": "瓚",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000038",
    "sentence": "抶幾斃，終無一言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000039",
    "sentence": "及吳平，瓚年老矣，黃冠野服，混跡編氓。",
    "entities": [
      {
        "text": "吳平",
        "label": "TME"
      },
      {
        "text": "瓚",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000040",
    "sentence": "洪武七年卒，年七十四。",
    "entities": [
      {
        "text": "洪武七年",
        "label": "TME"
      },
      {
        "text": "七十四",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000041",
    "sentence": "徐舫，字方舟，桐廬人。",
    "entities": [
      {
        "text": "徐舫",
        "label": "PER"
      },
      {
        "text": "方舟",
        "label": "PER"
      },
      {
        "text": "桐廬",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000042",
    "sentence": "幼輕俠，好擊劍、走馬、蹴踘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000043",
    "sentence": "既而悔之，習科舉業。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000044",
    "sentence": "已，復棄去，學為歌詩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000045",
    "sentence": "睦故多詩人，唐有方干、徐凝、李頻、施肩吾，宋有高師魯、滕元秀，號睦州詩派，舫悉取步聚之。",
    "entities": [
      {
        "text": "方干",
        "label": "PER"
      },
      {
        "text": "徐凝",
        "label": "PER"
      },
      {
        "text": "李頻",
        "label": "PER"
      },
      {
        "text": "施肩吾",
        "label": "PER"
      },
      {
        "text": "高師魯",
        "label": "PER"
      },
      {
        "text": "滕元秀",
        "label": "PER"
      },
      {
        "text": "睦州",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000046",
    "sentence": "既乃游四方，交其名士，詩益工。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000047",
    "sentence": "行省參政蘇天爵將薦之，舫笑曰：「吾詩人耳，可羈以章紱哉。」",
    "entities": [
      {
        "text": "行省參政",
        "label": "TITLE"
      },
      {
        "text": "蘇天爵",
        "label": "PER"
      },
      {
        "text": "章紱",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000048",
    "sentence": "竟避去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000049",
    "sentence": "築室江皋，日苦吟於雲煙出沒間，翛然若與世隔，因自號滄江散人。",
    "entities": [
      {
        "text": "江皋",
        "label": "LOC"
      },
      {
        "text": "雲煙",
        "label": "LOC"
      },
      {
        "text": "滄江散人",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000050",
    "sentence": "宋濂、劉基、葉琛、章溢之赴召也，舟溯桐江，忽有人黃冠鹿裘立江上，招基而笑，且語侵之。",
    "entities": [
      {
        "text": "宋濂",
        "label": "PER"
      },
      {
        "text": "劉基",
        "label": "PER"
      },
      {
