      {
        "text": "章溢",
        "label": "PER"
      },
      {
        "text": "桐江",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000051",
    "sentence": "基望見，急延入舟中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000052",
    "sentence": "琛、溢競歡謔，各取冠服服之，欲載上黟川，其人不可乃止。",
    "entities": [
      {
        "text": "黟川",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000053",
    "sentence": "濂初未相識，以問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000054",
    "sentence": "基曰：「此徐方舟也。」",
    "entities": [
      {
        "text": "基",
        "label": "PER"
      },
      {
        "text": "徐方舟",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_298_000055",
    "sentence": "濂因起共歡笑，酌酒而別。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000056",
    "sentence": "舫詩有《瑤林》、《滄江》二集。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_298_000057",
    "sentence": "年六十八，丙午春，卒於家。",
