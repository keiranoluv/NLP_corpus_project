        "text": "尚書",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_079_000028",
    "sentence": "遺言戒厚葬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_079_000029",
    "sentence": "恐人譽過情，自誌其墓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_079_000030",
    "sentence": "耶律賢適，字阿古真，於越魯不古之子。",
