        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_079_000003",
    "sentence": "其精如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_079_000004",
    "sentence": "會同初，登進士第，為盧龍巡捕官。",
