        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000077",
    "sentence": "吐渾怒，下吏，系幾百日。",
    "entities": [
      {
        "text": "吐渾",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000078",
    "sentence": "復引詰之，人望不屈，蕭喜曰：「君為民如此，後必大用。」",
    "entities": [
      {
        "text": "人望",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000079",
    "sentence": "以事聞於朝，悉從所請。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_105_000080",
    "sentence": "徙知涿州新城縣。",
    "entities": [
      {
        "text": "涿州新城縣",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000081",
    "sentence": "縣與宋接境，驛道所從出。",
    "entities": [
      {
        "text": "宋",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000082",
    "sentence": "人望治不擾，吏民畏愛。",
    "entities": [
      {
        "text": "人望",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000083",
    "sentence": "近臣有聘宋還者，帝問以外事，多薦之，擢中京度支司鹽鐵判官。",
    "entities": [
      {
        "text": "宋",
        "label": "ORG"
      },
      {
        "text": "中京度支司鹽鐵判官",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000084",
    "sentence": "轉南京三司度支判官，公私兼裕。",
    "entities": [
      {
        "text": "南京三司度支判官",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000085",
    "sentence": "遷警巡使。",
    "entities": [
      {
        "text": "警巡使",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000086",
    "sentence": "京城獄訟填委，人望處決，無一冤者。",
    "entities": [
      {
        "text": "人望",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000087",
    "sentence": "會檢括戶口，未兩旬而畢。",
    "entities": [
      {
        "text": "會檢括戶口",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000088",
    "sentence": "同知留守蕭保先怪而問之，人望曰：「民產若括之無遺，他日必長厚斂之弊，大率十得六七足矣。」",
    "entities": [
      {
        "text": "留守",
        "label": "TITLE"
      },
      {
        "text": "蕭保先",
        "label": "PER"
      },
      {
        "text": "人望",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000089",
    "sentence": "保先謝曰：「公慮遠，吾不及也。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_105_000090",
    "sentence": "先是，樞密使乙辛竊弄威柄，卒害太子。",
    "entities": [
      {
        "text": "樞密使",
        "label": "TITLE"
      },
      {
        "text": "乙辛",
        "label": "PER"
      },
      {
        "text": "太子",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000091",
    "sentence": "及天祚嗣位，將報父仇，選人望與蕭報恩究其事。",
    "entities": [
      {
        "text": "天祚",
        "label": "TITLE"
      },
      {
        "text": "人望",
        "label": "PER"
      },
      {
        "text": "蕭報恩",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000092",
    "sentence": "人望平心以處，所活甚眾。",
    "entities": [
      {
        "text": "人望",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000093",
    "sentence": "改上京副留守。",
