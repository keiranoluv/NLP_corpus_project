    "entities": []
  },
  {
    "sentence_id": "HCH_010_105_000030",
    "sentence": "頗聞怨詈語，曰：「此吾職，不敢廢也。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_105_000031",
