        "text": "人望",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000095",
    "sentence": "右臂中矢，炷以艾，力疾馳逐，賊棄所掠而遁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_105_000096",
    "sentence": "人望令關津譏察行旅，悉獲其盜。",
    "entities": [
      {
        "text": "人望",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000097",
    "sentence": "尋擢樞密都承旨。",
    "entities": [
      {
        "text": "樞密都承旨",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000098",
    "sentence": "宰相耶律儼惡人望與己異，遷南京諸宮提轄制置。",
    "entities": [
      {
        "text": "宰相",
        "label": "TITLE"
      },
      {
        "text": "耶律儼",
        "label": "PER"
      },
      {
        "text": "人望",
        "label": "PER"
      },
      {
        "text": "南京",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000099",
    "sentence": "歲中，為保靜軍節度使。",
    "entities": [
      {
        "text": "保靜軍",
        "label": "LOC"
      },
      {
        "text": "節度使",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000100",
    "sentence": "有二吏凶暴，民畏如虎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_105_000101",
    "sentence": "人望假以辭色，陰令發其事，黥配之。",
