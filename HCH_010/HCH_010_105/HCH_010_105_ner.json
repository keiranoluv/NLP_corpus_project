    ]
  },
  {
    "sentence_id": "HCH_010_105_000036",
    "sentence": "安輯如故。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_105_000037",
    "sentence": "拜中京留守，賜貞亮功臣，乘傳赴官。",
