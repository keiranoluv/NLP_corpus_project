        "text": "主簿",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000013",
    "sentence": "公鼎幼莊願，長而好學。",
    "entities": [
      {
        "text": "公鼎",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000014",
    "sentence": "咸雍十年，登進士第，調沈州觀察判官。",
