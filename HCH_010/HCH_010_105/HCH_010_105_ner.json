      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000003",
    "sentence": "然惟朝廷參置國官，吏州縣者多遵唐制。",
    "entities": [
      {
        "text": "唐",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000004",
    "sentence": "歷世既久，選舉益嚴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_105_000005",
    "sentence": "時又分遣重臣巡行境內，察賢否而進退之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_105_000006",
    "sentence": "是以治民、理財、決獄、弭盜，各有其人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_105_000007",
    "sentence": "考其德政，雖未足以與諸循、良之列，抑亦可謂能吏矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_105_000008",
    "sentence": "作《能吏傳》。",
    "entities": [
      {
        "text": "能吏傳",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000009",
    "sentence": "大公鼎，渤海人，先世籍遼陽率賓縣。",
