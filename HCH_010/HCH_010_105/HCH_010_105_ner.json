        "text": "文獻",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000120",
    "sentence": "人望有操守，喜怒不形，未嘗附麗求進。",
    "entities": [
      {
        "text": "人望",
        "label": "PER"
      }
    ]
  },
  {
