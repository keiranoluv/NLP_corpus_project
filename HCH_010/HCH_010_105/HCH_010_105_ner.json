      {
        "text": "人望",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000123",
    "sentence": "其畏慎如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_105_000124",
