        "text": "人望",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000074",
    "sentence": "幼孤，長以才學稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_105_000075",
    "sentence": "咸雍中，第進士，為松山縣令。",
