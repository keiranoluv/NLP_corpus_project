      }
    ]
  },
  {
    "sentence_id": "HCH_010_105_000109",
    "sentence": "奸人黠吏莫得軒輊，乃以年老揚言道路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_105_000110",
    "sentence": "朝論不察，改南院宣徽使，以示優老。",
