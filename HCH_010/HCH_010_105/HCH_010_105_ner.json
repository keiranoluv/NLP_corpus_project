  },
  {
    "sentence_id": "HCH_010_105_000023",
    "sentence": "歲久，民不堪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_105_000024",
    "sentence": "公鼎言於上，即命禁戢。",
    "entities": [
