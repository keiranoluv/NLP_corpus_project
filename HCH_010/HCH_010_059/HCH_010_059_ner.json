[
  {
    "sentence_id": "HCH_010_059_000001",
    "sentence": "契丹舊俗，其富以馬，其強以兵。",
    "entities": [
      {
        "text": "契丹",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_059_000002",
    "sentence": "縱馬於野，弛兵於民。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_059_000003",
    "sentence": "有事而戰，彍騎介夫，卯命辰集。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_059_000004",
    "sentence": "馬逐水草，人仰湩酪，挽強射生，以給日用，糗糧芻茭，道在是矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_059_000005",
    "sentence": "以是制勝，所向無前。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_059_000006",
    "sentence": "及其有國，內建宗廟朝廷，外置郡縣牧守，制度日增，經費日廣，上下相師，服御浸盛，而食貨之用斯為急矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_059_000007",
    "sentence": "於是五京及長春、遼西、平州置鹽鐵、轉運、度支、錢帛諸司，以掌出納。",
    "entities": [
