      }
    ]
  },
  {
    "sentence_id": "HCH_010_108_000059",
    "sentence": "往求之，果得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_108_000060",
    "sentence": "當時占候無不驗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_108_000061",
