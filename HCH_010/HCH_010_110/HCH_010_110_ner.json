        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_110_000005",
    "sentence": "耶律乙辛，字胡睹袞，五院部人。",
    "entities": [
      {
        "text": "耶律乙辛",
        "label": "PER"
      },
      {
        "text": "五院部",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_110_000006",
    "sentence": "父叠剌，家貧，服用不給，部人號「窮叠剌」。",
    "entities": [
      {
        "text": "叠剌",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_110_000007",
    "sentence": "初，乙辛母方娠，夜夢手搏羖羊，拔其角尾。",
    "entities": [
      {
        "text": "乙辛",
        "label": "PER"
      },
      {
        "text": "羖羊",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_110_000008",
    "sentence": "既寤占之，術者曰：「此吉兆也。羊去角尾為王字，汝後有子當王。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_110_000009",
    "sentence": "及乙辛生，適在路，無水以浴，回車破轍，忽見湧泉。",
    "entities": [
      {
        "text": "乙辛",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_110_000010",
    "sentence": "叠剌自以得子，欲酒以慶，聞酒香，於草棘間得二榼，因祭東焉。",
    "entities": [
      {
        "text": "叠剌",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_110_000011",
    "sentence": "乙辛幼慧黠。",
    "entities": [
      {
        "text": "乙辛",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_110_000012",
    "sentence": "嘗牧羊至日昃，叠剌視之，乙辛熟寢。",
    "entities": [
      {
        "text": "叠剌",
        "label": "PER"
      },
      {
        "text": "乙辛",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_110_000013",
    "sentence": "叠剌觸之覺，乙辛怒曰：「何遽驚我！適夢人手執日月以食我，我已食月，啖日方半而覺，惜不盡食之。」",
    "entities": [
      {
        "text": "叠剌",
        "label": "PER"
      },
      {
        "text": "乙辛",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_110_000014",
    "sentence": "叠剌自是不令牧羊。",
    "entities": [
      {
        "text": "叠剌",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_110_000015",
    "sentence": "及長，美風儀，外和內狡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_110_000016",
    "sentence": "重熙中，為文班吏，掌太保印，陪從入宮。",
