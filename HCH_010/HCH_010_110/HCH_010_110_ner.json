        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_110_000033",
    "sentence": "上信之，納於宮，尋冊為皇后。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_110_000034",
    "sentence": "時護衛蕭忽古知乙辛奸狀，伏橋下，欲殺之。",
