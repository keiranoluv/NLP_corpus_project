[
  {
    "sentence_id": "HCH_010_110_000001",
    "sentence": "《春秋》褒貶，善惡並書，示勸懲也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_110_000002",
    "sentence": "故遷、固傳佞幸、酷吏，歐陽修則並奸臣錄之，將俾為君者知所鑒，為臣者知所戒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_110_000003",
    "sentence": "此天地聖賢之心，國家安危之機，治亂之原也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_110_000004",
    "sentence": "遼自耶律乙辛而下，奸臣十人，其敗國皆足以為戒，故列於《傳》。",
    "entities": [
      {
        "text": "遼",
        "label": "ORG"
      },
      {
        "text": "耶律乙辛",
