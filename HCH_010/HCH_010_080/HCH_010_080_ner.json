    "entities": []
  },
  {
    "sentence_id": "HCH_010_080_000032",
    "sentence": "復即其第賜宴，器玩悉與之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_080_000033",
    "sentence": "二十二年薨，年九十一，敕葬宛平縣。",
