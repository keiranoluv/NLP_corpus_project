        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_080_000006",
    "sentence": "召見，容止樸野。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_080_000007",
    "sentence": "訪及世務，占奏三十餘事。",
    "entities": [
      {
        "text": "三十餘事",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_080_000008",
    "sentence": "由此顧遇特異，踐歷清華，號稱明幹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_080_000009",
    "sentence": "開泰中，累遷同知樞密院事。",
    "entities": [
      {
        "text": "同知樞密院事",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_080_000010",
    "sentence": "太平五年，出為武定軍節度使，移鎮大同。",
