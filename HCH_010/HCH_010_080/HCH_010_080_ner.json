        "text": "尚父",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_080_000014",
    "sentence": "重熙五年，帝幸禮部貢院及親試進士，皆儉發之。",
    "entities": [
