        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_080_000069",
    "sentence": "三不宜。",
    "entities": [
      {
        "text": "三不宜",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_080_000070",
    "sentence": "儻陛下不以臣言為迂，少賜省覽，天下之福，群臣之願也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_080_000071",
    "sentence": "書奏，帝嘉嘆良久。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_080_000072",
    "sentence": "未幾卒，贈太子太保，詔有司給葬。",
