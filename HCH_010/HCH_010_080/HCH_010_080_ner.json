        "text": "進士第",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_080_000022",
    "sentence": "有司獲盜八人，既戮之，乃獲正賊。",
    "entities": [
      {
        "text": "八人",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_080_000023",
    "sentence": "家人訴冤，儉三乞申理。",
    "entities": [
      {
        "text": "家人",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_080_000024",
    "sentence": "上勃然曰：「卿欲朕償命耶！」",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_080_000025",
    "sentence": "儉曰：「八家老稚無告，少加存恤，使得收葬，足慰存沒矣。」",
    "entities": [
      {
        "text": "八家",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_080_000026",
    "sentence": "乃從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_080_000027",
    "sentence": "儉在相位二十餘年，裨益為多。",
    "entities": [
      {
        "text": "二十餘",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_080_000028",
    "sentence": "致政歸第，會宋書辭不如禮，上將親征。",
