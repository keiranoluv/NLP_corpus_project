        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_127_000136",
    "sentence": "諸生服其教，無敢為非義者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_127_000137",
    "sentence": "同業嘗憫其貧，時周之，皆謝不受。",
    "entities": [
      {
        "text": "同業",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_127_000138",
    "sentence": "後不知所終。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_127_000139",
    "sentence": "宋可，字予之，武陟人。",
