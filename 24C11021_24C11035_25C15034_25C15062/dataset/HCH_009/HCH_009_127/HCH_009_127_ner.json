      }
    ]
  },
  {
    "sentence_id": "HCH_009_127_000133",
    "sentence": "始由律學為伊陽簿，秩滿，遂隱居不仕。",
    "entities": [
      {
        "text": "伊陽",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_127_000134",
    "sentence": "性嗜書，動有禮法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_127_000135",
    "sentence": "生徒以法經就學者，兼授以經學。",
