[
  {
    "sentence_id": "HCH_012_064_000000",
    "sentence": "《周官》，王之儀衛分掌於天官、春官、夏官之屬，而蹕事則專屬於秋官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_064_000001",
    "sentence": "漢朝會，則衛官陳車騎，張旗幟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_064_000002",
