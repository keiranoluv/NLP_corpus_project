        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_106_000023",
    "sentence": "官奴辭曰：「臣愚鈍，不任官使。」",
    "entities": [
      {
        "text": "官奴",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_106_000024",
