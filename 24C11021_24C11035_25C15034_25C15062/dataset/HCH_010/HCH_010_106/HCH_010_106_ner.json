      }
    ]
  },
  {
    "sentence_id": "HCH_010_106_000018",
    "sentence": "沈厚多學，詳於本朝世系。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_106_000019",
    "sentence": "嗜酒好佚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_106_000020",
    "sentence": "初，徵為宿直將軍。",
    "entities": [
      {
        "text": "宿直將軍",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_106_000021",
    "sentence": "重熙九年，以疾去官。",
    "entities": [
      {
        "text": "重熙九年",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_106_000022",
    "sentence": "上以官奴屬尊，欲成其志，乃許自擇一路節度使。",
