  },
  {
    "sentence_id": "HCH_010_106_000026",
    "sentence": "官奴然之。",
    "entities": [
      {
        "text": "官奴",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_106_000027",
    "sentence": "時稱「二逸」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_106_000028",
    "sentence": "乾統間，官奴卒。",
    "entities": [
