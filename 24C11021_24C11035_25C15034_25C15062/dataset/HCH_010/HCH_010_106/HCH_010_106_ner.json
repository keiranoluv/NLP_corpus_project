        "text": "卓行傳",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_106_000003",
    "sentence": "蕭劄剌，字虛輦，北府宰相排押之弟。",
    "entities": [
      {
        "text": "蕭劄剌",
        "label": "PER"
      },
