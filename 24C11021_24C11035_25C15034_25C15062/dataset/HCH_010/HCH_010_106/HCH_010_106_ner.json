      {
        "text": "排押",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_106_000004",
    "sentence": "性介特，不事生業。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_106_000005",
    "sentence": "保寧間，以戚屬進，累遷寧遠軍節度使。",
    "entities": [
      {
        "text": "寧遠軍節度使",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_106_000006",
    "sentence": "秩滿裏居，淡泊自適。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_106_000007",
    "sentence": "統和末，召為南京馬步軍都指揮使。",
    "entities": [
      {
        "text": "南京",
        "label": "LOC"
      },
      {
        "text": "馬步軍都指揮使",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_106_000008",
    "sentence": "以疾求退，不聽，遷夷離畢。",
    "entities": [
      {
        "text": "夷離畢",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_106_000009",
    "sentence": "又以疾辭，許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_106_000010",
    "sentence": "遂入頡山，杜門不出。",
    "entities": [
      {
        "text": "頡山",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_106_000011",
    "sentence": "上嘉其志，不復征，劄剌自是家於頡山。",
    "entities": [
      {
        "text": "劄剌",
        "label": "PER"
      },
      {
        "text": "頡山",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_106_000012",
    "sentence": "親友或過之，終日言不及世務。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_106_000013",
    "sentence": "凡宴遊相邀，亦不拒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_106_000014",
    "sentence": "一歲山居過半，與世俗不偶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_106_000015",
    "sentence": "耶律資忠重之，目曰頡山老人。",
    "entities": [
      {
        "text": "耶律資忠",
        "label": "PER"
      },
      {
        "text": "頡山老人",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_106_000016",
    "sentence": "卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_106_000017",
    "sentence": "耶律官奴，字奚隱，林牙斡魯之孫。",
