[
  {
    "sentence_id": "HCH_010_061_000000",
    "sentence": "刑也者，始於兵而終於禮者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_061_000001",
    "sentence": "鴻荒之代，生民有兵，如蠭有螫，自衞而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_061_000002",
    "sentence": "蚩尤惟始作亂，斯民鴟義，姦宄並作，刑之用豈能已乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_061_000003",
    "sentence": "帝堯清問下民，乃命三后恤功於民，伯夷降典，折民惟刑。",
    "entities": [
      {
        "text": "帝堯",
        "label": "TITLE"
      },
      {
        "text": "伯夷",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_061_000004",
    "sentence": "故曰刑也者，始於兵而終於禮者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_061_000005",
    "sentence": "先王順天地四時以建六卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_061_000006",
    "sentence": "秋，刑官也，象時之成物焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_061_000007",
    "sentence": "秋傳氣於夏，變色於春，推可知也。",
    "entities": [
      {
        "text": "夏",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_061_000008",
    "sentence": "遼以用武立國，禁暴戢姦，莫先於刑。",
    "entities": [
      {
        "text": "遼",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_061_000009",
    "sentence": "國初制法，有出於五服、三就之外者，兵之勢方張，禮之用未遑也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_061_000010",
    "sentence": "及阻午可汗知宗室雅里之賢，命為夷離菫以掌刑辟，豈非士師之官，非賢者不可為乎。",
    "entities": [
      {
        "text": "阻午可汗",
        "label": "TITLE"
      },
      {
        "text": "雅里",
        "label": "PER"
      },
      {
        "text": "夷離菫",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_061_000011",
    "sentence": "太祖、太宗經理疆土，擐甲之士歲無寧居，威克厥愛，理勢然也。",
    "entities": [
      {
        "text": "太祖",
        "label": "TITLE"
      },
      {
        "text": "太宗",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_061_000012",
    "sentence": "子孫相繼，其法互有輕重；中間能審權宜，終之以禮者，惟景、聖二宗為優耳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_061_000013",
    "sentence": "然其制刑之凡有四：曰死，曰流，曰徒，曰杖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_061_000014",
    "sentence": "死刑有絞、斬、凌遲之屬，又有籍沒之法。",
    "entities": [
      {
        "text": "死刑",
        "label": "TITLE"
      },
      {
        "text": "凌遲",
        "label": "TITLE"
      },
      {
        "text": "籍沒",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_061_000015",
    "sentence": "流刑量罪輕重，置之邊城部族之地，遠則投諸境外，又遠則罰使絕域。",
    "entities": [
      {
        "text": "流刑",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_061_000016",
    "sentence": "徒刑一曰終身，二曰五年，三曰一年半；終身者決五百，其次遞減百；又有黥刺之法。",
    "entities": [
      {
        "text": "二曰五年",
        "label": "TME"
      },
      {
        "text": "三曰一年",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_061_000017",
    "sentence": "杖刑自五十至三百，凡杖五十以上者，以沙袋決之；又有木劍、大棒、鐵骨朶之法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_061_000018",
    "sentence": "木劍、大棒之數三，自十五至三十；鐵骨朶之數，或五、或七。",
    "entities": [
      {
        "text": "木劍",
        "label": "LOC"
      },
      {
        "text": "大棒",
        "label": "LOC"
      },
      {
        "text": "鐵骨朶",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_061_000019",
    "sentence": "有重罪者，將決以沙袋，先于脽骨之上及四周擊之。",
    "entities": [
      {
        "text": "周",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_061_000020",
    "sentence": "拷訊之具，有麄、細杖及鞭、烙法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_061_000021",
    "sentence": "麄杖之數二十；細杖之數三，自三十至于六十。",
    "entities": [
      {
        "text": "麄杖",
        "label": "TITLE"
      },
      {
        "text": "二十",
        "label": "NUM"
      },
      {
        "text": "細杖",
        "label": "TITLE"
      },
      {
        "text": "三",
        "label": "NUM"
      },
      {
        "text": "三十",
        "label": "NUM"
      },
      {
        "text": "六十",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_061_000022",
    "sentence": "鞭、烙之數，凡烙三十者鞭三百，烙五十者鞭五百。",
    "entities": [
      {
        "text": "三十",
        "label": "NUM"
      },
      {
        "text": "三百",
        "label": "NUM"
      },
      {
        "text": "五十",
        "label": "NUM"
      },
      {
        "text": "五百",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_061_000023",
    "sentence": "被告諸事應伏而不服者，以此訊之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_061_000024",
    "sentence": "品官公事誤犯，民年七十以上、十五以下犯罪者，聽以贖論。",
    "entities": [
      {
        "text": "七十",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_061_000025",
    "sentence": "贖銅之數，杖一百者，輸錢千。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_061_000026",
    "sentence": "亦有八議、八縱之法。",
    "entities": [
      {
        "text": "八議",
        "label": "TITLE"
      },
      {
        "text": "八縱",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_061_000027",
    "sentence": "籍沒之法，始自太祖為撻馬狘沙里時，奉痕德菫可汗命，按于越釋魯遇害事，以其首惡家屬沒入瓦里。",
    "entities": [
      {
        "text": "太祖",
        "label": "TITLE"
      },
      {
        "text": "撻馬",
        "label": "TITLE"
      },
      {
