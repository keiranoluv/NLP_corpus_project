        "text": "一日",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_109_000020",
    "sentence": "帝始悟，不復戲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_109_000021",
    "sentence": "清寧間，以疾卒。",
    "entities": []
  },
