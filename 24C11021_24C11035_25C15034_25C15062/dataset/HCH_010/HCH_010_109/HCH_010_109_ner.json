    "entities": [
      {
        "text": "數城",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_109_000018",
    "sentence": "重元既恃梁孝王之寵，又多鄭叔段之過，朝臣無敢言者，道路以目。",
    "entities": [
      {
        "text": "重元",
        "label": "PER"
      },
      {
        "text": "梁孝王",
        "label": "TITLE"
