[
  {
    "sentence_id": "HCH_015_016_000000",
    "sentence": "建官設職，興自炎昊，方乎隆周之冊，表乎盛漢之書。",
    "entities": []
  },
  {
    "sentence_id": "HCH_015_016_000001",
    "sentence": "存改回沿，備於歷代，先賢往學，以之雕篆者眾矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_015_016_000002",
    "sentence": "若夫胡廣舊儀，事惟簡撮，應劭官典，殆無遺恨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_015_016_000003",
    "sentence": "王朗奏議，屬霸國之初基；陳矯增曹，由軍事而補闕。",
