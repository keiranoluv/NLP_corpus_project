        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_016_001_000008",
    "sentence": "復棄于林中，適會伐木之人多。",
    "entities": []
  },
  {
    "sentence_id": "HCH_016_001_000009",
    "sentence": "復置于澤中冰上，眾鳥以羽覆之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_016_001_000010",
    "sentence": "后稷遂得不死。",
