    "entities": []
  },
  {
    "sentence_id": "HCH_016_001_000005",
    "sentence": "後妊娠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_016_001_000006",
    "sentence": "恐被淫泆之禍，遂祭祀以求，謂無子履上帝之跡，天猶令有之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_016_001_000007",
    "sentence": "姜嫄怪而棄于阨狹之巷，牛馬過者折易而避之。",
