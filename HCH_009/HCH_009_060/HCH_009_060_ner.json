    "sentence_id": "HCH_009_060_000001",
    "sentence": "天下之勢，曷有常哉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_060_000002",
    "sentence": "金人日尋干戈，撫制諸郡，保其疆圉，以求逞志於遼也，豈一日哉。",
