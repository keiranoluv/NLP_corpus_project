        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_060_000009",
    "sentence": "金人豈愛宋人而為和哉！",
    "entities": [
      {
        "text": "金",
        "label": "ORG"
      },
      {
        "text": "宋人",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_060_000010",
    "sentence": "策既失矣，名既屈矣，假使高宗立歸德，不得河北，可保河南、山東，不然，亦不失為晉元帝，其孰能亡之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_060_000011",
    "sentence": "金不能奄有四海，而宋人以尊稱與之，是誰強之邪。",
    "entities": [
      {
        "text": "金",
        "label": "ORG"
      },
      {
        "text": "宋人",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_060_000012",
    "sentence": "金人出於高麗，始通好為敵國，後稱臣。",
    "entities": [
      {
        "text": "金",
        "label": "ORG"
      },
      {
        "text": "高麗",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_060_000013",
    "sentence": "夏國始稱臣，末年為兄弟，于其國自為帝。",
    "entities": [
      {
        "text": "夏國",
        "label": "ORG"
      },
      {
        "text": "兄弟",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_060_000014",
    "sentence": "宋于金初或以臣禮稱「表」，終以侄禮往復稱「書」。",
    "entities": [
      {
        "text": "宋",
        "label": "ORG"
