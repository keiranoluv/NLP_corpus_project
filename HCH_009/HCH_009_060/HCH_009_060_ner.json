      }
    ]
  },
  {
    "sentence_id": "HCH_009_060_000005",
    "sentence": "遼人過計，宋人亦過計，海上之書曰：「克遼之後，五代時陷入契丹漢地願畀下邑。」",
    "entities": [
      {
