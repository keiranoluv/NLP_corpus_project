  {
    "sentence_id": "HCH_009_021_000143",
    "sentence": "日法：四分之三：三千九百二十二半。",
    "entities": [
      {
        "text": "日法",
        "label": "TITLE"
      },
      {
        "text": "四分之三",
        "label": "NUM"
      },
      {
        "text": "三千九百二十二半",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000144",
    "sentence": "日法：四分之一：一千三百七半。",
    "entities": [
      {
        "text": "日法",
        "label": "TITLE"
      },
      {
        "text": "四分之一",
        "label": "NUM"
      },
      {
        "text": "一千三百七半",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000145",
    "sentence": "昏明分：一百三十分，七十五秒。",
    "entities": [
      {
        "text": "一百三十分",
        "label": "NUM"
      },
      {
        "text": "七十五秒",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000146",
    "sentence": "昏明刻：二刻，一百五十六分，九十秒。",
    "entities": [
      {
        "text": "二刻",
        "label": "NUM"
      },
      {
        "text": "一百五十六分",
        "label": "NUM"
      },
      {
        "text": "九十秒",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000147",
    "sentence": "刻法：三百一十三分，八十秒。",
    "entities": [
      {
        "text": "刻法",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000148",
    "sentence": "秒母：一百。",
    "entities": [
      {
        "text": "秒母",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000149",
    "sentence": "置所求日大餘及半法，以所入之氣大小餘減之，為其日午中入氣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000150",
    "sentence": "以加其氣中積，為其日午中中積。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000151",
    "sentence": "小餘以日法除為約分。",
    "entities": [
      {
        "text": "日法",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000152",
    "sentence": "置午中中積及分，如中限以下，為冬至後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000153",
    "sentence": "以上去中限，為夏至後。",
    "entities": [
      {
        "text": "夏",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000154",
    "sentence": "其二至後，如在初限以下，為初限。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000155",
    "sentence": "以上覆減中限，餘為入末限也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000156",
    "sentence": "視冬至後初限、夏至後末限，百通日，內分，自相乘，副置之。",
    "entities": [
      {
        "text": "夏",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000157",
    "sentence": "以一千四百五十除之，所得加五萬三百八十，折半限分並之；除其副為分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000158",
    "sentence": "分滿十為寸，寸滿十為尺，用減冬至地中晷影常數，為所求晷影定數。",
    "entities": [
      {
        "text": "十",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000159",
    "sentence": "視夏至後初限、冬至後末限，百通日，內分，自相乘為上位。",
    "entities": [
      {
        "text": "夏",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000160",
    "sentence": "下置入限分，以二百二十五乘，百約之，加一十九萬八千七十五為法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000161",
    "sentence": "夏至前後半限以上者，減去半限，列於上位。",
    "entities": [
      {
        "text": "夏",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000162",
    "sentence": "下位置半限。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000163",
    "sentence": "各百通日，內分，先相減，後相乘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000164",
    "sentence": "以七千七百除之，所得以加其法反除上位，為分，分滿十為寸，寸滿十為尺，用加夏至地中晷影常數，為所求晷影定數。",
    "entities": [
      {
        "text": "十",
        "label": "NUM"
      },
      {
        "text": "夏",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000165",
    "sentence": "各於其處測冬夏二至晷影，乃相減之餘，為其處二至晷差。",
    "entities": [
      {
        "text": "夏",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000166",
    "sentence": "亦以地中二至晷數相減，為地中二至晷差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000167",
    "sentence": "其所求日在冬至後初限、夏至後末限者，如在半限以下，倍之；半限以上，覆減半限，餘亦倍之，併入限日，三因折半，以日為分，十為寸，以減地中二至晷差為法。",
    "entities": [
      {
        "text": "夏",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000168",
    "sentence": "置地中冬至晷影常數，以所求日地中晷影定數減之，餘以其年二至晷差乘之為實。",
    "entities": [
      {
        "text": "二",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000169",
    "sentence": "實如法而一，所得，以減其處冬至晷數，即得其處其日晷影定數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000170",
    "sentence": "所求日在夏至後初限、冬至後末限者，如在半限以下，倍之；半限以上，覆減半限，餘亦倍之，併入限日，三因四除，以日為分，十為寸，以加地中二至晷差為法。",
    "entities": [
      {
        "text": "夏",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000171",
    "sentence": "置所求日地中晷影定數，以地中夏至晷影常數減之，餘以其處二至晷差乘之為實。",
    "entities": [
      {
        "text": "夏",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000172",
    "sentence": "實如法而一，所得，以加其處夏至晷數，即得其處其日晷影定數。",
    "entities": [
      {
        "text": "夏",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000173",
    "sentence": "春分前三日太陽入赤道內，秋分後三日太陽出赤道外，故其陟降與他日不倫，今各別立數而用之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000174",
    "sentence": "驚蟄，十二日，陟四六十七，一十六此為末率，于此用畢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000175",
    "sentence": "其減差亦止於此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000176",
    "sentence": "十三日，陟四四十一，六。",
    "entities": [
      {
        "text": "四四十一",
        "label": "NUM"
      },
      {
        "text": "六",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000177",
    "sentence": "十四日，陟四三十六，九十。",
    "entities": [
      {
        "text": "四三十六",
        "label": "NUM"
      },
      {
        "text": "九十",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000178",
    "sentence": "十五日，陟四一。",
    "entities": [
      {
        "text": "四一",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000179",
    "sentence": "秋分，初日，降四三十八。",
    "entities": [
      {
        "text": "降四三十八",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000180",
    "sentence": "一日，降四三十九。",
    "entities": [
      {
        "text": "一日",
        "label": "TME"
      },
      {
        "text": "四三十九",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000181",
    "sentence": "二日，降四五十七。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000182",
    "sentence": "三日降四六十八。",
    "entities": [
      {
        "text": "三日",
        "label": "PER"
      },
      {
        "text": "四六十八",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000183",
    "sentence": "此為初率，始用之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000184",
    "sentence": "其加差亦始於此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000185",
    "sentence": "各以陟降初率，陟減降加其氣初日日出分，為一日下日出分。",
    "entities": [
      {
        "text": "一日",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000186",
    "sentence": "以增損差，仍加減加減差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000187",
    "sentence": "增損陟降率，馴積而加減之，即為每日日出分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000188",
    "sentence": "覆減日法，餘為日入分。",
    "entities": [
      {
        "text": "日法",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000189",
    "sentence": "以日出分日入分而半之，為半晝分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000190",
    "sentence": "以昏明分減日出分為晨分，加日入分為昏分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000191",
    "sentence": "置日出入分，以六因之，滿辰法而一，為辰數，不盡，刻法除之為刻數，不滿為分，命子正算外，即得所求。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000192",
    "sentence": "置日出分，十二乘之，刻法而一，為刻，不滿為分，即為夜刻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000193",
    "sentence": "覆減百刻，餘為晝刻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000194",
    "sentence": "置晨分，四因，退位為更率。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000195",
    "sentence": "二因更率，退位為點率。",
    "entities": [
      {
        "text": "二因",
        "label": "NUM"
      },
      {
        "text": "更率",
        "label": "TITLE"
      },
      {
        "text": "點率",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000196",
    "sentence": "置更點率，以所求更點數因之，又六因，內加昏明分，滿辰法而一，為辰數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000197",
    "sentence": "不盡，滿刻法除之為刻數，不滿為分，命其辰刻算外，即得所求。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000198",
    "sentence": "各於所在下水漏，以定其處冬至或夏至夜刻，乃與五十刻相減，餘為至差刻。",
    "entities": [
      {
        "text": "夏",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000199",
    "sentence": "置所求日黃道去赤道內外度及分，以至差刻乘之，進一位，如二百三十九而一，為刻，不盡以刻法乘之，退除為分，內減外加五十刻，即所求日夜刻，以減百刻，餘為晝刻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000200",
    "sentence": "其日出入辰刻及更點差率算等，並依術求之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000201",
    "sentence": "置日出分，如日法四分之一以上，去之，餘為外分。",
    "entities": [
      {
        "text": "日法",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000202",
    "sentence": "如日法四分之一以下，覆減之，餘為內分。",
    "entities": [
      {
        "text": "日法",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000203",
    "sentence": "置內外分，千乘之，如內外法而一，為度，不滿退除為分，即為黃道去赤道內外度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000204",
    "sentence": "內減外加象限，即得內道去極度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000205",
    "sentence": "置半法，以晨分減之，餘為距中分，百乘之，如周法而一，為距中度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000206",
    "sentence": "用減一百八十三度一十二分八十四秒，餘四因退位，為每更差度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000207",
    "sentence": "置距中度，以其日午中赤道日度加而命之，即昏中星所格宿次，因為初更中星。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_021_000208",
    "sentence": "以更差度累加之，命赤道宿次去之，即得逐更及明中星。",
    "entities": []
  }
]