      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000126",
    "sentence": "大暑，柳四度九十五分一十六秒外，入周分，鶉火之次，辰在午。",
    "entities": [
      {
        "text": "周分",
        "label": "LOC"
      },
      {
        "text": "鶉火",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_021_000127",
    "sentence": "處暑，張十五度五十六分三十五秒外，入楚分，鶉尾之次，辰在巳。",
