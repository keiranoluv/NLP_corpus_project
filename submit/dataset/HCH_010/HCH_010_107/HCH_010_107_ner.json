        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_107_000007",
    "sentence": "父陘，五代時累官司徒。",
    "entities": [
      {
        "text": "司徒",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_107_000008",
    "sentence": "陳氏甫笄，涉通經義，凡覽詩賦，輒能誦，尤好吟詠，時以女秀才名之。",
    "entities": [
      {
        "text": "陳氏",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_107_000009",
    "sentence": "年二十，歸於簡。",
    "entities": [
      {
        "text": "二十",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_107_000010",
    "sentence": "孝舅姑，閨門和睦，親黨推重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_107_000011",
    "sentence": "有六子，陳氏親教以經。",
