        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_107_000044",
    "sentence": "帝感其言，從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_107_000045",
    "sentence": "意辛久在貶所，親執役事，雖勞無難色。",
    "entities": [
