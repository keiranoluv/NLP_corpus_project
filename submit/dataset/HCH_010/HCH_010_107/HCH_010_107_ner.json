[
  {
    "sentence_id": "HCH_010_107_000000",
    "sentence": "男女居室，人之大倫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_107_000001",
    "sentence": "與其得烈女，不若得賢女。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_107_000002",
    "sentence": "天下而有烈女之名，非幸也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_107_000003",
    "sentence": "《詩》贊衛共姜，《春秋》褒宋伯姬，蓋不得已，所以重人倫之變也。",
    "entities": [
      {
        "text": "宋",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_107_000004",
    "sentence": "遼據北方，風化視中土為疏。",
    "entities": [
      {
        "text": "遼",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_107_000005",
    "sentence": "終遼之世，得賢女二，烈女三，以見人心之天理有不與世道存亡者。",
    "entities": [
      {
        "text": "遼",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_107_000006",
    "sentence": "邢簡妻陳氏，營州人。",
