        "text": "鎮州",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_107_000029",
    "sentence": "人問曰：「何自苦如此？」",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_107_000030",
    "sentence": "對曰：「皇儲無罪遭廢，我輩豈可美食安寢。」",
    "entities": [
      {
        "text": "皇儲",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_107_000031",
    "sentence": "及太子被害，不勝哀痛。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_107_000032",
    "sentence": "年七十，卒於家。",
