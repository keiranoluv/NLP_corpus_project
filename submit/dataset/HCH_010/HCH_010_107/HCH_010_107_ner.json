        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_107_000013",
    "sentence": "統和十二年卒。",
    "entities": [
      {
        "text": "統和十二年",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_107_000014",
    "sentence": "睿智皇后聞之，嗟悼，贈魯國夫人，刻石以表其行。",
    "entities": [
