      {
        "text": "六子",
        "label": "NUM"
      },
      {
        "text": "陳氏",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_107_000012",
    "sentence": "後二子抱樸、抱質皆以賢，位宰相。",
    "entities": [
      {
        "text": "二子",
        "label": "NUM"
      },
      {
