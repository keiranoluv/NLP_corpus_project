        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_107_000015",
    "sentence": "及遷祔，遣使以祭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_107_000016",
    "sentence": "論者謂貞靜柔順，婦道母儀始終無慊雲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_107_000017",
    "sentence": "耶律氏，太師適魯之妹，小字常哥。",
    "entities": [
      {
        "text": "耶律氏",
        "label": "ORG"
      },
