[
  {
    "sentence_id": "HCH_010_104_000000",
    "sentence": "王鼎，字虚中，涿州人。",
    "entities": [
      {
        "text": "王鼎",
        "label": "PER"
      },
      {
        "text": "虚中",
        "label": "PER"
