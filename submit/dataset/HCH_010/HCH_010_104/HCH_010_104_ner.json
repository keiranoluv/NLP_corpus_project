      {
        "text": "涿州",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000001",
    "sentence": "幼好學，居太寧山數年，博通經史。",
    "entities": [
      {
        "text": "居太寧山數年",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000002",
    "sentence": "時馬唐俊有文名燕、薊間，適上巳，與同志祓禊水濱，酌酒賦詩。",
    "entities": [
      {
        "text": "馬唐俊",
        "label": "PER"
      },
      {
        "text": "燕",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000003",
    "sentence": "鼎偶造席，唐俊見鼎樸野，置下坐。",
    "entities": [
      {
        "text": "唐俊",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000004",
    "sentence": "欲以詩困之，先出所作索賦，鼎援筆立成。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000005",
    "sentence": "唐俊驚其敏妙，因與定交。",
    "entities": [
      {
        "text": "唐俊",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000006",
    "sentence": "淸寧五年，擢進士第。",
    "entities": [
      {
        "text": "淸寧五年",
        "label": "TME"
      },
      {
        "text": "進士",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000007",
    "sentence": "調易州觀察判官，改淶水縣令，累遷翰林學士。",
    "entities": [
      {
        "text": "易州",
        "label": "LOC"
      },
      {
        "text": "觀察判官",
        "label": "TITLE"
      },
      {
        "text": "淶水縣",
        "label": "LOC"
      },
      {
        "text": "翰林學士",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000008",
    "sentence": "當代典章多出其手。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000009",
    "sentence": "上書言治道十事，帝以鼎達政體，事多咨訪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000010",
    "sentence": "鼎正直不阿，人有過，必面詆之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000011",
    "sentence": "壽隆初，升觀書殿學士。",
    "entities": [
      {
        "text": "觀書殿學士",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000012",
    "sentence": "一日宴主第，醉與客忤，怨上不知己，坐是下吏。",
    "entities": [
      {
        "text": "一日",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000013",
    "sentence": "狀聞，上大怒，杖黥奪官，流鎭州。",
    "entities": [
      {
        "text": "杖黥",
        "label": "TITLE"
      },
      {
        "text": "奪官",
        "label": "TITLE"
      },
      {
        "text": "鎭州",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000014",
    "sentence": "居數歳，有赦，鼎獨不免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000015",
    "sentence": "會守臣召鼎爲賀表，因以詩貽使者，有「誰知天雨露，獨不到孤寒」之句。",
    "entities": [
      {
        "text": "賀表",
        "label": "TITLE"
      },
      {
        "text": "孤寒",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000016",
    "sentence": "上聞而憐之，即召還，復其職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000017",
    "sentence": "乾統六年卒。",
    "entities": [
      {
        "text": "乾統六年",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000018",
    "sentence": "鼎宰縣時，憩於庭，俄有暴風舉臥榻空中。",
    "entities": [
      {
        "text": "鼎宰縣",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000019",
    "sentence": "鼎無懼色，但覺枕榻倶髙，乃曰：「吾中朝端士，邪無干正，可徐置之。」",
    "entities": [
      {
        "text": "中朝",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000020",
    "sentence": "須臾，榻復故處，風遂止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000021",
    "sentence": "耶律昭，字述寧，博學，善屬文。",
    "entities": [
      {
        "text": "耶律昭",
        "label": "PER"
      },
      {
        "text": "述寧",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000022",
    "sentence": "統和中，坐兄國留事，流西北部。",
    "entities": [
      {
        "text": "國留",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000023",
    "sentence": "會蕭撻凜爲西北路招討使，愛之，奏免其役，禮致門下。",
    "entities": [
      {
        "text": "蕭撻凜",
        "label": "PER"
      },
      {
        "text": "西北路招討使",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000024",
    "sentence": "欲召用，以疾辭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000025",
    "sentence": "撻凜問曰：「今軍旅甫罷，三邊宴然，惟阻卜伺隙而動。討之則路遠難至，縱之則邊民被掠，增戍兵則饋餉不給，欲茍一時之安，不能終保無變。計將安出？」",
    "entities": [
      {
        "text": "撻凜",
        "label": "PER"
      },
      {
        "text": "阻卜",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000026",
    "sentence": "昭以書答曰：竊聞治得其要，則仇敵爲一家；失其術，則部曲爲行路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000027",
    "sentence": "夫西北諸部，毎當農時，一夫爲偵候，一夫治公田，二夫給糺官之役，大率四丁無一室處。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000028",
    "sentence": "芻牧之事，仰給妻孥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000029",
    "sentence": "一遭寇掠，貧窮立至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000030",
    "sentence": "春夏賑恤，吏多雜以糠比，重以掊克，不過數月，又復告困。",
    "entities": [
      {
        "text": "夏",
        "label": "ORG"
      },
      {
        "text": "數月",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000031",
    "sentence": "且畜牧者，富國之本。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000032",
    "sentence": "有司防其隱沒，聚之一所，不得各就水草便地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000033",
    "sentence": "兼以逋亡戍卒，隨時補調，不習風土，故日瘠月損，馴至耗竭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000034",
    "sentence": "爲今之計，莫若振窮薄賦，給以牛種，使遂耕獲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000035",
    "sentence": "置遊兵以防盜掠，頒俘獲以助伏臘，散畜牧以就便地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000036",
    "sentence": "期以數年，富強可望。",
    "entities": [
      {
        "text": "期以數年",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000037",
    "sentence": "然後練簡精兵，以備行伍，何守之不固，何動而不克哉？",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000038",
    "sentence": "然必去其難制者，則余種自畏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000039",
    "sentence": "若舍大而謀小，避強而攻弱，非徒虚費財力，亦不足以威服其心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000040",
    "sentence": "此二者，利害之機，不可不察。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000041",
    "sentence": "昭聞古之名將，安邊立功，在德不在衆。",
    "entities": [
      {
        "text": "昭聞",
        "label": "TITLE"
      },
      {
        "text": "名將",
        "label": "PER"
      },
      {
        "text": "安邊",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000042",
    "sentence": "故謝玄以八千破苻堅百萬，休哥以五隊敗曹彬十萬。",
    "entities": [
      {
        "text": "謝玄",
        "label": "PER"
      },
      {
        "text": "八千",
        "label": "NUM"
      },
      {
        "text": "苻堅",
        "label": "PER"
      },
      {
        "text": "百萬",
        "label": "NUM"
      },
      {
        "text": "休哥",
        "label": "PER"
      },
      {
        "text": "五隊",
        "label": "PER"
      },
      {
        "text": "曹彬",
        "label": "PER"
      },
      {
        "text": "十萬",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000043",
    "sentence": "良由恩結士心，得其死力也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000044",
    "sentence": "閣下膺非常之遇，專方面之寄，宜遠師古人，以就勛業。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000045",
    "sentence": "上觀乾象，下盡人謀；察地形之險易，料敵勢之虚實。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000046",
    "sentence": "慮無遺策，利施後世矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000047",
    "sentence": "撻凜然之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000048",
    "sentence": "開泰中，獵於拔裏堵山，爲羯羊所觸，卒。",
    "entities": [
      {
        "text": "拔裏堵山",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000049",
    "sentence": "劉輝，好學善屬文，疎簡有遠略。",
    "entities": [
      {
        "text": "劉輝",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000050",
    "sentence": "大康五年，第進士。",
    "entities": [
      {
        "text": "大康五年",
        "label": "TME"
      },
      {
        "text": "進士",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000051",
    "sentence": "大安末，爲太子洗馬，上書言：「西邊諸番爲患，士卒遠戍，中國之民疲於飛挽，非長久之策。爲今之務，莫若城於鹽濼，實以漢戸，使耕田聚糧，以爲西北之費。」",
    "entities": [
      {
        "text": "太子洗馬",
        "label": "TITLE"
      },
      {
        "text": "漢",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000052",
    "sentence": "言雖不行，識者韙之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_104_000053",
    "sentence": "壽隆二年，復上書曰：「宋歐陽修編《五代史》，附我朝於四夷，妄加貶訾。且宋人賴我朝寬大，許通和好，得盡兄弟之禮。今反令臣下妄意作史，恬不經意。臣請以趙氏初起事跡，詳附國史。」",
    "entities": [
      {
        "text": "壽隆二年",
        "label": "TME"
      },
      {
        "text": "宋",
        "label": "ORG"
      },
      {
