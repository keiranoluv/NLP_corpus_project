        "text": "趙氏",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000054",
    "sentence": "上嘉其言，遷禮部郎中。",
    "entities": [
      {
        "text": "其言",
        "label": "PER"
      },
      {
        "text": "禮部郎中",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000055",
    "sentence": "詔以賢良對策，輝言多中時病。",
    "entities": [
      {
        "text": "賢良",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000056",
    "sentence": "擢史館修撰，卒。",
    "entities": [
      {
        "text": "史館修撰",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_104_000057",
    "sentence": "耶律孟簡，字復易，於越屋質之五世孫。",
    "entities": [
      {
        "text": "耶律孟簡",
        "label": "PER"
      },
      {
