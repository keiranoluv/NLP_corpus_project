      },
      {
        "text": "執事郎君",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000140",
    "sentence": "巫及大巫以次贊祝火神訖，閣門使贊皇帝面火再拜。",
    "entities": [
      {
        "text": "大巫",
        "label": "PER"
      },
      {
        "text": "火神",
        "label": "PER"
      },
      {
        "text": "閣門使",
        "label": "TITLE"
      },
      {
        "text": "皇帝",
