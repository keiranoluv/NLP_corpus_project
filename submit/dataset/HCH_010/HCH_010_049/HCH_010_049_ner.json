[
  {
    "sentence_id": "HCH_010_049_000000",
    "sentence": "理自天設，情由人生。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000001",
    "sentence": "以理制情，而禮樂之用行焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000002",
    "sentence": "林豺梁獺，是生郊禘；窪尊燔黍，是生燕饗；虆梩瓦棺，是生喪葬；儷皮緇布，是生婚冠。",
    "entities": [
      {
        "text": "梁",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000003",
    "sentence": "皇造帝秩，三王彌文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000004",
    "sentence": "一文一質，蓋本於忠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000005",
    "sentence": "變通革弊，與時宜之，唯聖人為能通其意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000006",
    "sentence": "執理者膠瑟聚訟，不適人情；徇情者梯稗綿蕝，不中天理。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000007",
    "sentence": "秦漢而降，君子無取焉。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000008",
    "sentence": "遼本朝鮮故壤，箕子八條之教，流風遺俗，蓋有存者。",
    "entities": [
      {
        "text": "遼",
        "label": "ORG"
      },
      {
        "text": "朝鮮",
        "label": "LOC"
      },
      {
        "text": "箕子",
        "label": "PER"
      },
      {
        "text": "八條",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000009",
    "sentence": "自其上世，緣情制宜，隱然有尚質之風。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000010",
    "sentence": "遙輦胡剌可汗制祭山儀，蘇可汗制瑟瑟儀，阻午可汗制柴冊、再生儀。",
    "entities": [
      {
        "text": "遙輦胡剌可汗",
        "label": "TITLE"
      },
      {
        "text": "蘇可汗",
        "label": "TITLE"
      },
      {
        "text": "阻午可汗",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000011",
    "sentence": "其情樸，其用儉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000012",
    "sentence": "敬天恤災，施惠本孝，出於悃忱，殆有得於膠瑟聚訟之表者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000013",
    "sentence": "太古之上，椎輪五禮，何以異茲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000014",
    "sentence": "太宗克晉，稍用漢禮。",
    "entities": [
      {
        "text": "太宗",
        "label": "TITLE"
      },
      {
        "text": "晉",
        "label": "ORG"
      },
      {
        "text": "漢",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000015",
    "sentence": "今國史院有金陳大任《遼禮儀志》，皆其國俗之故，又有《遼朝雜禮》，漢儀為多。",
    "entities": [
      {
        "text": "金陳大任",
        "label": "PER"
      },
      {
        "text": "遼禮儀志",
        "label": "ORG"
      },
      {
        "text": "遼朝雜禮",
        "label": "ORG"
      },
      {
        "text": "漢",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000016",
    "sentence": "別得宣文閣所藏耶律儼《志》，視大任為加詳。",
    "entities": [
      {
        "text": "耶律儼",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000017",
    "sentence": "存其略，著於篇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000018",
    "sentence": "祭山儀：設天神、地祇位於木葉山，東向；中立君樹，前植群樹，以像朝班；又偶植二樹，以為神門。",
    "entities": [
      {
        "text": "木葉山",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000019",
    "sentence": "皇帝、皇后至，夷離畢具禮儀。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      },
      {
        "text": "夷離畢",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000020",
    "sentence": "牲用赭白馬、玄牛、赤白羊，皆牡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000021",
    "sentence": "仆臣曰旗鼓拽剌，殺牲，體割，懸之君樹。",
    "entities": [
      {
        "text": "仆臣",
        "label": "PER"
      },
      {
        "text": "旗鼓拽剌",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000022",
    "sentence": "太巫以酒酹牲。",
    "entities": [
      {
        "text": "太巫",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000023",
    "sentence": "禮官曰敵烈麻都，奏「儀辦」。",
    "entities": [
      {
        "text": "敵烈麻都",
        "label": "PER"
      },
      {
        "text": "儀辦",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000024",
    "sentence": "皇帝服金文金冠，白綾袍，絳帶，懸魚，三山絳垂，飾犀玉刀錯，絡縫烏靴。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "三山",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000025",
    "sentence": "皇后禦絳末，絡縫紅袍，懸玉佩，雙結帕，絡縫烏靴。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE"
      },
      {
        "text": "絳末",
        "label": "LOC"
      },
      {
        "text": "紅袍",
        "label": "LOC"
      },
      {
        "text": "玉佩",
        "label": "LOC"
      },
      {
        "text": "雙結帕",
        "label": "LOC"
      },
      {
        "text": "烏靴",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000026",
    "sentence": "皇帝、皇后禦鞍馬。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000027",
    "sentence": "群臣在南，命婦在北，服從各部旗幟之色以從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000028",
    "sentence": "皇帝、皇后至君樹前下馬，升南壇禦榻坐。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      },
      {
        "text": "君樹",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000029",
    "sentence": "群臣命婦分班，以次入就位；合班，拜訖，復位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000030",
    "sentence": "皇帝皇后詣天神、地祇位，致奠；閣門使讀祝訖，復位坐。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      },
      {
        "text": "天神",
        "label": "LOC"
      },
      {
        "text": "地祇",
        "label": "LOC"
      },
      {
        "text": "閣門使",
        "label": "TITLE"
      },
      {
        "text": "讀祝",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000031",
    "sentence": "北府宰相及惕隱以次致奠於君樹，遍及群樹。",
    "entities": [
      {
        "text": "北府宰相",
        "label": "TITLE"
      },
      {
        "text": "惕隱",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000032",
    "sentence": "樂作。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000033",
    "sentence": "群臣、命婦退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000034",
    "sentence": "皇帝率孟父、仲父、季父之族，三匝神門樹；餘族七匝。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "孟父",
        "label": "TITLE"
      },
      {
        "text": "仲父",
        "label": "TITLE"
      },
      {
        "text": "季父",
        "label": "TITLE"
      },
      {
        "text": "神門",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000035",
    "sentence": "皇帝、皇后再拜，在位者皆再拜。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000036",
    "sentence": "上香，再拜如初。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000037",
    "sentence": "皇帝、皇后升壇，禦龍文方茵坐。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000038",
    "sentence": "再聲警，詣祭東所，群臣、命婦從，班列如初。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000039",
    "sentence": "巫衣白衣，惕隱以素巾拜而冠之，巫三致辭。",
    "entities": [
      {
        "text": "惕隱",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000040",
    "sentence": "每致辭，皇帝、皇后一拜，在位者皆一拜。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000041",
    "sentence": "皇帝、皇后各舉酒二爵，肉二器，再奠。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000042",
    "sentence": "大臣、命婦右持酒，左持肉各一器，少後立，一奠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000043",
    "sentence": "命惕隱東向擲之。",
    "entities": [
      {
        "text": "惕隱",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000044",
    "sentence": "皇帝、皇后六拜，在位者皆六拜。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000045",
    "sentence": "皇帝、皇后復位，坐。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000046",
    "sentence": "命中丞奉茶果、餅餌各二器奠於天神、地祇位。",
    "entities": [
      {
        "text": "命中丞",
        "label": "TITLE"
      },
      {
        "text": "天神",
        "label": "LOC"
      },
      {
        "text": "地祇",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000047",
    "sentence": "執事郎君二十人持福酒、胙肉，詣皇帝、皇后前。",
    "entities": [
      {
        "text": "執事郎君",
        "label": "TITLE"
      },
      {
        "text": "二十人",
        "label": "NUM"
      },
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000048",
    "sentence": "太巫奠酹訖，皇帝、皇后再拜，在位者皆再拜。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000049",
    "sentence": "皇帝、皇后一拜，飲福，受胙，復位，坐。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000050",
    "sentence": "在位者以次飲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000051",
    "sentence": "皇帝、皇后率群臣復班位，再拜。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000052",
    "sentence": "聲蹕，一拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000053",
    "sentence": "退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000054",
    "sentence": "太宗幸幽州大悲閣，遷白衣觀音像，建廟木葉山，尊為家神。",
    "entities": [
      {
        "text": "太宗",
        "label": "TITLE"
      },
      {
        "text": "幽州",
        "label": "LOC"
      },
      {
        "text": "大悲閣",
        "label": "LOC"
      },
      {
        "text": "白衣觀音",
        "label": "PER"
      },
      {
        "text": "木葉山",
        "label": "LOC"
      },
      {
        "text": "家神",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000055",
    "sentence": "於拜山儀過樹之後，增詣菩薩堂儀一節，然後拜神，非胡剌可汗之故也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000056",
    "sentence": "興宗先有事於菩薩堂及木葉山遼河神，然後行拜山儀，冠服、節文多所變更，後因以為常。",
    "entities": [
      {
        "text": "興宗",
        "label": "TITLE"
      },
      {
        "text": "菩薩堂",
        "label": "LOC"
      },
      {
        "text": "木葉山",
        "label": "LOC"
      },
      {
        "text": "遼河神",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000057",
    "sentence": "神主樹木，懸牲告辦，班位奠祝，致嘏飲福，往往暗合於禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000058",
    "sentence": "天理人情，放諸四海而準，信矣夫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000059",
    "sentence": "興宗更制，不能正以經術，無以大過於昔，故不載。",
    "entities": [
      {
        "text": "興宗",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000060",
    "sentence": "瑟瑟儀：若旱，擇吉日行瑟瑟儀以祈雨。",
    "entities": [
      {
        "text": "瑟瑟儀",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000061",
    "sentence": "前期，置百柱天棚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000062",
    "sentence": "及期，皇帝致奠於先帝御容，乃射柳。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "先帝",
        "label": "TITLE"
      },
      {
        "text": "御容",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000063",
    "sentence": "皇帝再射，親王、宰執以次各一射。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "親王",
        "label": "TITLE"
      },
      {
        "text": "宰執",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000064",
    "sentence": "中柳者質誌柳者冠服，不中者以冠服質之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000065",
    "sentence": "不勝者進飲於勝者，然後各歸其冠服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000066",
    "sentence": "又翼日，植柳天棚之東南，巫以酒醴、黍稗薦植柳，祝之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000067",
    "sentence": "皇帝、皇后祭東方畢，子弟射柳。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      },
      {
        "text": "東方",
        "label": "LOC"
      },
      {
        "text": "子弟",
        "label": "TITLE"
      },
      {
        "text": "射柳",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000068",
    "sentence": "皇族、國舅、群臣與禮者，賜物有差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000069",
    "sentence": "既三日雨，則賜敵烈麻都馬四匹、衣四襲；否則以水沃之。",
    "entities": [
      {
        "text": "四匹",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000070",
    "sentence": "道宗清寧元年，皇帝射柳訖，詣風師壇，再拜。",
    "entities": [
      {
        "text": "道宗清寧元年",
        "label": "TME"
      },
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "射柳",
        "label": "TITLE"
      },
      {
        "text": "風師壇",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000071",
    "sentence": "柴冊儀：擇吉日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000072",
    "sentence": "前期，置柴冊殿及壇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000073",
    "sentence": "壇之制，厚積薪，以木為三級，壇置其上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000074",
    "sentence": "席百尺氈，龍文方茵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000075",
    "sentence": "又置再生母後搜索之室。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000076",
    "sentence": "皇帝入再生室，行再生儀畢，八部之叟前導後扈，左右扶翼皇帝冊殿之東北隅。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "八部",
        "label": "NUM"
      },
      {
        "text": "冊殿",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000077",
    "sentence": "拜日畢，乘馬，選外戚之老者禦。",
    "entities": [
      {
        "text": "外戚",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000078",
    "sentence": "皇帝疾馳，仆禦者、從者以氈覆之。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000079",
    "sentence": "皇帝詣高阜地，大臣、諸部帥列儀仗，遙望以拜。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "高阜地",
        "label": "LOC"
      },
      {
        "text": "大臣",
        "label": "TITLE"
      },
      {
        "text": "諸部帥",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000080",
    "sentence": "皇帝遣使敕曰：「先帝升遐，有伯叔父兄在，當選賢者。沖人不德，何以為謀？」",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "先帝",
        "label": "TITLE"
      },
      {
        "text": "伯叔父兄",
        "label": "PER"
      },
      {
        "text": "沖人",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000081",
    "sentence": "群臣對曰：「臣等以先帝厚恩，陛下明德，咸願盡心，敢有他圖。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000082",
    "sentence": "皇帝令曰：「必從汝等所願，我將信明賞罰。爾有功，陟而任之；爾有罪，黜而棄之。若聽朕命，則當謨之。」",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000083",
    "sentence": "僉曰：「唯帝命是從。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000084",
    "sentence": "皇帝於所識之地，封土石以誌之。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000085",
    "sentence": "遂行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000086",
    "sentence": "拜先帝御容，宴饗群臣。",
    "entities": [
      {
        "text": "先帝",
        "label": "TITLE"
      },
      {
        "text": "御容",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000087",
    "sentence": "翼日，皇帝出冊殿，護衛太保扶翼升壇。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "冊殿",
        "label": "LOC"
      },
      {
        "text": "護衛太保",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000088",
    "sentence": "奉七廟神主置龍文方茵。",
    "entities": [
      {
        "text": "七廟",
        "label": "LOC"
      },
      {
        "text": "龍文方茵",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000089",
    "sentence": "北、南府宰相率群臣圜立，各舉氈邊，贊祝訖，樞密使奉玉寶、玉冊入。",
    "entities": [
      {
        "text": "南府宰相",
        "label": "TITLE"
      },
      {
        "text": "樞密使",
        "label": "TITLE"
      },
      {
        "text": "玉冊",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000090",
    "sentence": "有司讀冊訖，樞密使稱尊號以進，群臣三稱萬歲，皆拜。",
    "entities": [
      {
        "text": "樞密使",
        "label": "TITLE"
      },
      {
        "text": "萬歲",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000091",
    "sentence": "宰相、北南院大王、諸部帥進赭、白羊各一群。",
    "entities": [
      {
        "text": "宰相",
        "label": "TITLE"
      },
      {
        "text": "北南院大王",
        "label": "TITLE"
      },
      {
        "text": "諸部帥",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000092",
    "sentence": "皇帝更衣，拜諸帝御容。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "諸帝",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000093",
    "sentence": "遂宴群臣，賜賚各有差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000094",
    "sentence": "拜日儀：皇帝升露臺，設褥，向日再拜，上香。",
    "entities": [
      {
        "text": "日儀",
        "label": "TITLE"
      },
      {
        "text": "皇帝",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000095",
    "sentence": "門使通，閣使或副，應拜臣僚殿左右階陪位，再拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000096",
    "sentence": "皇帝升坐。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000097",
    "sentence": "奏榜訖，北班起居畢，時相已下通名再拜，不出班，奏「聖躬萬福」，又再拜，各祗候。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000098",
    "sentence": "宣徽已下橫班同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000099",
    "sentence": "諸司、閣門、北面先奏事；餘同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000100",
    "sentence": "教坊與臣僚同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000101",
    "sentence": "告廟儀：至日，臣僚昧爽朝服，詣太祖廟。",
    "entities": [
      {
        "text": "太祖廟",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000102",
    "sentence": "次引臣僚，合班，先見御容，再拜畢，引班首左上，至褥位，再拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000103",
    "sentence": "贊上香，揖欄內上香畢，復褥位，再拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000104",
    "sentence": "各祗候立定。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000105",
    "sentence": "左右舉告廟祝版，於御容前跪捧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000106",
    "sentence": "中書舍人俯跪，讀訖，俯興，退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000107",
    "sentence": "引班首左下，復位，又再拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000108",
    "sentence": "分引上殿，次第進酒三。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000109",
    "sentence": "分班引出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000110",
    "sentence": "謁廟儀：至日昧爽，南北臣僚各具朝服，赴廟。",
    "entities": [
      {
        "text": "謁廟儀",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000111",
    "sentence": "車駕至，臣僚於門外依位序立，望駕鞠躬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000112",
    "sentence": "班首不出班，奏「聖躬萬福」。",
    "entities": [
      {
        "text": "聖躬萬福",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000113",
    "sentence": "舍人贊各祗候畢，皇帝降車，分引南北臣僚左右入，至丹墀褥位。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000114",
    "sentence": "合班定，皇帝升露臺褥位。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "露臺",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000115",
    "sentence": "宣徽贊皇帝再拜，殿上下臣僚陪位皆再拜。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000116",
    "sentence": "上香畢，退，復位，再拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000117",
    "sentence": "分引臣僚左右上殿位立，進御容酒依常禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000118",
    "sentence": "若即退，再拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000119",
    "sentence": "舍人贊「好去」，引退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000120",
    "sentence": "禮畢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000121",
    "sentence": "告廟、謁廟，皆曰拜容。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000122",
    "sentence": "以先帝、先後生辰及忌辰行禮，自太宗始也。",
    "entities": [
      {
        "text": "太宗",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000123",
    "sentence": "其後正旦、皇帝生辰、諸節辰皆行之。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000124",
    "sentence": "若忌辰及車駕行幸，亦嘗遣使行禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000125",
    "sentence": "凡瑟瑟、柴冊、再生、納後則親行之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000126",
    "sentence": "凡柴冊、親征則告；幸諸京則謁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000127",
    "sentence": "四時有薦新。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000128",
    "sentence": "孟冬朔拜陵儀：有司設酒饌於山陵。",
    "entities": [
      {
        "text": "山陵",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000129",
    "sentence": "皇帝、皇后駕至，敵烈麻都奏「儀辦」。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      },
      {
        "text": "敵烈麻都",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000130",
    "sentence": "閣門使贊皇帝、皇后詣位四拜訖，巫贊祝燔胙及時服，酹酒薦牲。",
    "entities": [
      {
        "text": "閣門使",
        "label": "TITLE"
      },
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000131",
    "sentence": "大臣、命婦以次燔胙，四拜。",
    "entities": [
      {
        "text": "大臣",
        "label": "TITLE"
      },
      {
        "text": "命婦",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000132",
    "sentence": "皇帝、皇后率群臣、命婦，循諸陵各三匝。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "皇后",
        "label": "TITLE"
      },
      {
        "text": "命婦",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000133",
    "sentence": "還宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000134",
    "sentence": "翼日，群臣入謝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_049_000135",
    "sentence": "爇節儀：皇帝即位，凡征伐叛國俘掠人民，或臣下進獻人口，或犯罪沒官戶，皇帝親覽閑田，建州縣以居之，設官治其事。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      },
      {
        "text": "進獻人口",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000136",
    "sentence": "及帝崩，所置人戶、府庫、錢粟，穹廬中置小氈殿，帝及后妃皆鑄金像納焉。",
    "entities": [
      {
        "text": "穹廬",
        "label": "LOC"
      },
      {
        "text": "小氈殿",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000137",
    "sentence": "節辰、忌日、朔望，皆致祭於穹廬之前。",
    "entities": [
      {
        "text": "穹廬",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000138",
    "sentence": "又築土為臺，高丈餘，置大盤於上，祭酒食撒於其中，焚之，國俗謂之爇節。",
    "entities": [
      {
        "text": "祭酒",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_049_000139",
    "sentence": "歲除儀：初夕，敕使及夷離畢率執事郎君至殿前，以鹽及羊膏置爐中燎之。",
    "entities": [
