      }
    ]
  },
  {
    "sentence_id": "HCH_010_052_000201",
    "sentence": "皇族迎者、後族送者遍賜酒，皆相偶飲訖，後坐別殿，送後者退食於次。",
    "entities": [
      {
        "text": "後族",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_052_000202",
    "sentence": "媒者傳旨命送後者列於殿北。",
