    "sentence_id": "HCH_010_052_000194",
    "sentence": "向謁者一拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_052_000195",
    "sentence": "起居訖，再拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_052_000196",
    "sentence": "次詣舅姑御容拜，奠酒。",
