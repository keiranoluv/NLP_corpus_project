      }
    ]
  },
  {
    "sentence_id": "HCH_010_052_000163",
    "sentence": "冊案置橫街北少東。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_052_000164",
    "sentence": "引使副等面殿立而鞠躬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_052_000165",
    "sentence": "侍中臨軒稱「有制」，皆再拜，鞠躬。",
    "entities": [
      {
        "text": "侍中",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_052_000166",
    "sentence": "宣制訖，舞蹈，五拜，引冊於宣慶門出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_052_000167",
    "sentence": "使副等押領儀仗、冊案，赴各私第廳前，向闕陳列。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_052_000168",
    "sentence": "設傳宣受冊拜褥，冊案置褥左，去冪蓋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_052_000169",
    "sentence": "使副案右序立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_052_000170",
    "sentence": "受冊者就位立，傳宣稱「有制」，再拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_052_000171",
    "sentence": "宣制畢，舁冊人舉冊匣於褥前跪捧，引讀冊者與受冊者皆俯伏跪，讀訖，皆俯伏興。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_052_000172",
    "sentence": "受冊者謝恩，國王五拜，王妃、公主四拜。",
    "entities": [
      {
        "text": "國王",
        "label": "TITLE"
      },
      {
        "text": "王妃",
        "label": "TITLE"
      },
      {
        "text": "公主",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_052_000173",
    "sentence": "若冊禮同日，先上皇太后冊寶，次臨軒同制，遣使冊皇后、諸王妃主，次冊皇太子。",
    "entities": [
      {
        "text": "皇太后",
        "label": "TITLE"
      },
      {
        "text": "冊寶",
        "label": "TITLE"
      },
