      }
    ]
  },
  {
    "sentence_id": "HCH_010_052_000176",
    "sentence": "詰旦，後出私舍，坐於堂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_052_000177",
    "sentence": "皇帝遣使及媒者，以牲酒饔餼至門。",
