      },
      {
        "text": "御容",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_052_000199",
    "sentence": "神賜襲衣、珠玉、珮飾，拜受服之。",
    "entities": [
      {
        "text": "神賜",
        "label": "TITLE"
      },
      {
