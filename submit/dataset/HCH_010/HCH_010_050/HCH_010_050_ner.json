        "text": "太巫",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_050_000005",
    "sentence": "皇族、外戚、大臣、諸京官以次致祭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000006",
    "sentence": "乃以衣、弓矢、鞍勒、圖畫、馬駝、儀衛等物皆燔之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000007",
    "sentence": "至山陵，葬畢，上哀冊。",
