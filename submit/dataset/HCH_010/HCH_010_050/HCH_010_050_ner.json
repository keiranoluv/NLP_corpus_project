        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_050_000036",
    "sentence": "先置冊、寶案於西廊下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000037",
    "sentence": "閣使引皇帝至禦幄，服寬衣皂帶。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_050_000038",
    "sentence": "臣僚班齊，分班引入，響殿合班立定。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000039",
    "sentence": "引冊案上殿至褥位，寶案次之，設於西階。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000040",
    "sentence": "閣使引皇帝自西階升殿。",
    "entities": [
