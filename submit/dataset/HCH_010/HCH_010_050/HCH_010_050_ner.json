      {
        "text": "翰林使",
        "label": "TITLE"
      },
      {
        "text": "皇帝",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_050_000044",
    "sentence": "引皇至神座前，跪奠三，樂作，進奠訖，復位，樂止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000045",
    "sentence": "又再拜，陪位者皆再拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000046",
    "sentence": "引帝於神座前。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000047",
    "sentence": "北面立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000048",
    "sentence": "捧冊函者去蓋，進前跪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000049",
    "sentence": "冊案退，置殿西壁下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000050",
    "sentence": "引讀冊者進前，俯伏跪，自通全銜臣讀謚冊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000051",
    "sentence": "讀訖，俯伏興，復位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000052",
    "sentence": "捧冊函者置於案上，捧寶函者進前跪，讀寶官通銜跪讀訖，引皇帝至褥位再拜，陪位者皆再拜。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_050_000053",
    "sentence": "禮畢，引皇帝歸禦幄。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_050_000054",
    "sentence": "初行，樂作；至禦幄，樂止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000055",
    "sentence": "引臣僚分班出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000056",
    "sentence": "若皇太后奠酒，依常儀。",
