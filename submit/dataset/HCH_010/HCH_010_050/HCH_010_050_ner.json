        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_050_000041",
    "sentence": "初行，樂作；至位立，樂止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000042",
    "sentence": "宣徽使揖皇帝鞠躬再拜，陪位者皆再拜。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_050_000043",
    "sentence": "翰林使執臺盞以進，皇帝再拜。",
