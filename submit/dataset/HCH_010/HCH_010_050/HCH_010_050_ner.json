  },
  {
    "sentence_id": "HCH_010_050_000002",
    "sentence": "巫者袚除之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000003",
    "sentence": "詰旦，發引，至祭，凡五致奠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000004",
    "sentence": "太巫祈禳。",
