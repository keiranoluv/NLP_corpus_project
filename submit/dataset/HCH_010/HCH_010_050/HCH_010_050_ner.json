        "text": "宋使",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_050_000150",
    "sentence": "引出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000151",
    "sentence": "控鶴官門外祗候，報閣門無事供奉官卷班出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000152",
    "sentence": "高麗、夏國告終儀：先期，於先宮左右下禦帳，設使客幕次於東南。",
    "entities": [
      {
        "text": "高麗",
        "label": "ORG"
      },
      {
        "text": "夏國",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_050_000153",
    "sentence": "至日，北面臣僚各常服，其餘臣僚並朝服，入朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000154",
    "sentence": "使者至幕次，有司以嗣子表狀先呈樞密院，準備奏呈。",
    "entities": [
      {
        "text": "嗣子",
        "label": "TITLE"
      },
      {
        "text": "樞密院",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_050_000155",
    "sentence": "先引北面臣僚並矮墩已上近禦帳，相對立，其餘臣僚依班位序立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000156",
    "sentence": "引告終人使右入，至丹墀，面殿立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000157",
    "sentence": "引右上，立；揖少前，拜，跪奏訖，宣問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000158",
    "sentence": "若嗣子已立，恭身受聖旨。",
    "entities": [
      {
        "text": "已",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_050_000159",
    "sentence": "奏訖，復位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000160",
    "sentence": "嗣子未立。",
    "entities": [
      {
        "text": "未",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_050_000161",
    "sentence": "不宣問，引右下丹墀，面北鞠躬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000162",
    "sentence": "通班畢，引面殿再拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000163",
    "sentence": "不出班，奏「聖躬萬福」，再拜。",
    "entities": [
      {
        "text": "聖躬萬福",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_050_000164",
    "sentence": "出班，謝面天顏，復位，再拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000165",
    "sentence": "出班，謝遠接，復位，再拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000166",
    "sentence": "贊祗候，退就幕次。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000167",
    "sentence": "再入，依前面北鞠躬，通辭，再拜；敘戀闕，再拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000168",
    "sentence": "贊「好去」。",
    "entities": [
      {
        "text": "好去",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_050_000169",
    "sentence": "禮畢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_050_000170",
