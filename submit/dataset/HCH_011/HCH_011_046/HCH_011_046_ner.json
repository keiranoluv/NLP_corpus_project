        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000015",
    "sentence": "侯景聞之遂遁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_046_000016",
    "sentence": "世祖以僧祐爲侍中、領軍將軍，徵還荊州。",
