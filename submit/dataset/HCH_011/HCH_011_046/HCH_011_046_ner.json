        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000011",
    "sentence": "世祖聞而壯之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_046_000012",
    "sentence": "至楊浦，景遣其將任約率銳卒五千，據白塉，遙以待之。",
