      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000024",
    "sentence": "世仕魏爲將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_046_000025",
    "sentence": "父慶之，天監初，率千餘人自北歸款，未至道卒。",
    "entities": [
      {
        "text": "慶之",
        "label": "PER"
      },
      {
        "text": "天監",
        "label": "TME"
      },
