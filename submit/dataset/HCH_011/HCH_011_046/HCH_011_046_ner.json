        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000034",
    "sentence": "擊任約於貝磯，約大敗，退保西陽。",
    "entities": [
      {
        "text": "任約",
        "label": "PER"
      },
      {
        "text": "貝磯",
        "label": "LOC"
      },
      {
        "text": "西陽",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000035",
    "sentence": "文盛進據蘆洲，又與相持。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_046_000036",
    "sentence": "侯景聞之，乃率大衆西上援約，至西陽。",
    "entities": [
      {
        "text": "侯景",
        "label": "PER"
      },
      {
        "text": "西陽",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000037",
    "sentence": "文盛不敢戰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_046_000038",
    "sentence": "諸將咸曰：「景水軍輕進，又甚饑疲，可因此擊之，必大捷。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_046_000039",
    "sentence": "文盛不許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_046_000040",
    "sentence": "文盛妻石氏，先在建鄴，至是，景載以還之。",
    "entities": [
      {
        "text": "文盛",
        "label": "PER"
      },
      {
        "text": "石氏",
        "label": "PER"
      },
      {
        "text": "建鄴",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000041",
    "sentence": "文盛深德景，遂密通信使，都無戰心，衆咸憤怨。",
    "entities": [
      {
        "text": "文盛",
        "label": "PER"
      },
      {
        "text": "景",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000042",
    "sentence": "杜幼安、守簉等乃率所領獨進，與景戰，大破之，獲其舟艦以歸。",
    "entities": [
      {
        "text": "杜幼安",
        "label": "PER"
      },
      {
        "text": "守簉",
        "label": "PER"
      },
      {
        "text": "景",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000043",
    "sentence": "會景密遣騎從間道襲陷郢州，軍中兇懼，遂大潰。",
    "entities": [
      {
        "text": "景",
        "label": "PER"
      },
      {
        "text": "郢州",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000044",
    "sentence": "文盛奔還荊州，世祖仍以爲城北面都督。",
    "entities": [
      {
        "text": "文盛",
        "label": "PER"
      },
      {
        "text": "荊州",
        "label": "LOC"
      },
      {
        "text": "世祖",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000045",
    "sentence": "又聚贓汚甚多，世祖大怒，下令責之，數其十罪，除其官爵。",
    "entities": [
      {
        "text": "世祖",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000046",
    "sentence": "文盛旣失兵權，私懷怨望，世祖聞之，乃以下獄。",
    "entities": [
      {
        "text": "文盛",
        "label": "PER"
      },
      {
        "text": "世祖",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000047",
    "sentence": "時任約被擒，與文盛同禁。",
    "entities": [
      {
        "text": "任約",
        "label": "PER"
      },
      {
        "text": "文盛",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000048",
    "sentence": "文盛謂約曰：「汝何不早降，令我至此。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_046_000049",
    "sentence": "約曰：「門外不見卿馬跡，使我何遽得降？」",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_046_000050",
    "sentence": "文盛無以答，遂死獄中。",
    "entities": []
  },
