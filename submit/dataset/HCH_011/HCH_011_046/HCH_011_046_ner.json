      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000019",
    "sentence": "魏軍四面起攻，百道齊舉，僧祐親當矢石，晝夜督戰，獎勵將士，明於賞罰，衆皆感之，咸爲致死，所向摧殄，賊莫敢前。",
    "entities": [
      {
        "text": "僧祐",
        "label": "PER"
      },
      {
        "text": "矢石",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000020",
    "sentence": "俄而中流矢卒，時年六十三。",
    "entities": [
      {
        "text": "六十三",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000021",
    "sentence": "世祖聞之，馳往臨哭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_046_000022",
    "sentence": "於是內外惶駭，城遂陷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_046_000023",
    "sentence": "徐文盛，字道茂，彭城人也。",
