        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000026",
    "sentence": "文盛仍統其衆，稍立功績，高祖甚優寵之。",
    "entities": [
      {
        "text": "文盛",
        "label": "PER"
      },
      {
        "text": "高祖",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000027",
    "sentence": "大同末，以爲持節、督寧州刺史。",
    "entities": [
      {
        "text": "大同",
        "label": "TME"
      },
      {
        "text": "持節",
        "label": "TITLE"
      },
      {
