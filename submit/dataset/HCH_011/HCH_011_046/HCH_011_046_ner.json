        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000028",
    "sentence": "先是，州在僻遠，所管羣蠻不識教義，貪欲財賄，劫篡相尋，前後刺史莫能制。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_046_000029",
    "sentence": "文盛推心撫慰，示以威德，夷獠感之，風俗遂改。",
    "entities": [
      {
        "text": "文盛",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_046_000030",
    "sentence": "太清二年，聞國難，乃召募得數萬人來赴。",
    "entities": [
      {
        "text": "太清二年",
        "label": "TME"
      },
      {
        "text": "數萬人",
        "label": "NUM"
      }
    ]
  },
  {
