[
  {
    "sentence_id": "HCH_012_111_000000",
    "sentence": "七卿，前史無表也，曷為表？",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_111_000001",
    "sentence": "明太祖十三年罷丞相，政歸六部，部權重也。",
    "entities": [
      {
        "text": "明太祖",
        "label": "TITLE"
      },
      {
        "text": "十三年",
        "label": "TME"
      },
      {
        "text": "六部",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_111_000002",
    "sentence": "洪、宣以後，閣體既尊，而權亦漸重，於是閣部相持，凡廷推考察，各騁意見，以營其私，而黨局分焉。",
    "entities": [
      {
        "text": "洪",
        "label": "TME"
      },
      {
        "text": "宣",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_111_000003",
    "sentence": "科道庶僚，乘其間隙，參奏紛拿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_111_000004",
    "sentence": "馴至神宗，厭其囂聒，置而不論，而被核多者，其人自去。",
    "entities": [
      {
        "text": "神宗",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_111_000005",
    "sentence": "逮熹宗朝，則正論澌滅矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_111_000006",
    "sentence": "莊烈矯之，卒不能救。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_111_000007",
    "sentence": "二百七十年間，七卿之正直而獨立者若而人，偏邪而嫉能者若而人，貪庸而媚宰輔者若而人，備列之，可以觀世變矣，作七卿表。",
    "entities": [
      {
        "text": "二百七十年",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_111_000008",
    "sentence": "自洪武十三年始。",
    "entities": [
      {
        "text": "洪武十三年",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_111_000009",
    "sentence": "成祖遷都，南京止設侍郎，仁宗乃有尚書、都御史而未備。",
