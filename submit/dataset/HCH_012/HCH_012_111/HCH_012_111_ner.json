      },
      {
        "text": "都御史",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_111_000010",
    "sentence": "備官自孝宗始，其權位重者曰參贊機務，憲宗後乃專屬之兵部。",
    "entities": [
      {
        "text": "孝宗",
        "label": "TITLE"
