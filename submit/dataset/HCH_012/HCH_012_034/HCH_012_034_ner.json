[
  {
    "sentence_id": "HCH_012_034_000000",
    "sentence": "立成者，以日月五星盈縮遲疾之數，預爲排定，以便推步取用也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_034_000001",
    "sentence": "《元志》、《曆經》步七政盈縮遲疾，皆有二術。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_034_000002",
    "sentence": "其一術以三差立算者，即布立成法也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_034_000003",
    "sentence": "其又術雲，以其下盈縮分，乘入限分萬約之，以加其下盈縮積者，用立成法也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_034_000004",
    "sentence": "而遣立成未載，無從入算。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_034_000005",
    "sentence": "今依《大統歷通軌》具錄之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_034_000006",
    "sentence": "其目四：曰太陽盈縮，曰晨昏分，曰太陰遲疾，曰五星盈縮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_034_000007",
    "sentence": "餘詳《法原》及《推步》卷中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_034_000008",
    "sentence": "按《元史》，至正十七年《授時曆》成。",
    "entities": [
      {
        "text": "至正十七年",
        "label": "TME"
      },
      {
        "text": "《授時曆》",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_034_000009",
    "sentence": "十九年王恂卒，時歷雖頒，然立成之數尚皆有定藁。",
    "entities": [
      {
        "text": "十九年",
        "label": "TME"
      },
      {
        "text": "王恂",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_034_000010",
    "sentence": "郭守敬比類編次，整齊分秒，裁爲二卷。",
    "entities": [
      {
        "text": "郭守敬",
        "label": "PER"
      },
      {
        "text": "二卷",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_034_000011",
    "sentence": "而今欽天監本，載嘉議大夫太史令臣王恂奉敕撰。",
    "entities": [
      {
        "text": "欽天監",
        "label": "ORG"
      },
      {
        "text": "嘉議大夫",
        "label": "TITLE"
      },
      {
        "text": "太史令",
        "label": "TITLE"
      },
      {
        "text": "王恂",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_034_000012",
    "sentence": "意者王先有藁，而郭卒成之歟？",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_034_000013",
    "sentence": "晨分加二百五十分，爲日出分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_034_000014",
    "sentence": "日週一萬分，內減晨分爲昏分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_034_000015",
    "sentence": "昏分減二百五十分，爲日入分，又減五千分，爲半晝分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_034_000016",
    "sentence": "故立成只列晨昏分，則出入及半晝分皆具，不必盡列也。",
    "entities": []
  }
