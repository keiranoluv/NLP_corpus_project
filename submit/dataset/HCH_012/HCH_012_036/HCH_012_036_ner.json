  },
  {
    "sentence_id": "HCH_012_036_000021",
    "sentence": "又視定朔小余在日出前、日入後二十分已上者，日食在夜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000022",
    "sentence": "定望小余在日入前、日出後八刻二十分已上者，月食在晝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000023",
    "sentence": "皆不必布算。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000024",
    "sentence": "經朔盈縮歷盈縮差遲疾歷遲疾差加減差定朔入交凡分以上皆全錄之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000025",
    "sentence": "定入遲疾歷以加減差，加減遲疾即是。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000026",
    "sentence": "遲疾定限置定入遲疾歷，以日轉限一十二限二十分乘之，小余不用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000027",
    "sentence": "定限行度以定限，取立成內行度，遲用遲，疾用疾，內減日行分八分二十秒，得之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000028",
    "sentence": "日出分以盈縮歷，從立成內取之，下同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000029",
    "sentence": "日入分半晝分取立成內昏分，減去五千二百五十分，得之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000030",
    "sentence": "歲前冬至時黃道宿次推交常度置有食之朔入交凡分，以月平行度乘之，即得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000031",
    "sentence": "推交定度置交常度，以朔下盈縮差盈加縮減之，即得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000032",
    "sentence": "推日食正交限度視交定度在七度已下，三百四十一度已上者，食在正交。",
    "entities": [
      {
        "text": "七度",
        "label": "NUM"
      },
      {
        "text": "三百四十一度",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000033",
    "sentence": "在一百七十五度已上，二百零二度已下者，食在中交。",
    "entities": [
      {
        "text": "一百七十五度",
        "label": "NUM"
      },
      {
        "text": "二百零二度",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000034",
    "sentence": "不在限內不食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000035",
    "sentence": "推中前中後分視定朔小余，在半日周已下，用減半日周，餘爲中前分。",
    "entities": [
      {
        "text": "半日",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000036",
    "sentence": "在半日周已上，減去半日周，餘爲中後分。",
    "entities": [
      {
        "text": "半日",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000037",
    "sentence": "推時差置半日擊，以中前、中後分減之，餘以中後分乘之，所得以九千六百而一爲時差。",
    "entities": [
      {
        "text": "半日",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000038",
    "sentence": "在中前爲減，中後爲加。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000039",
    "sentence": "推食甚定分置定朔小余，以時差加減之，即得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000040",
    "sentence": "推距午定分置中前、中後分，加時差即得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000041",
    "sentence": "但加不減。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000042",
    "sentence": "推食甚入盈縮歷置原得盈縮歷，加入定朔大餘及食甚定分，即得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000043",
    "sentence": "推食甚盈縮差依步氣朔求之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000044",
    "sentence": "推食甚入盈縮歷行定度置食甚入盈縮歷，盈縮差，盈加縮減之，即得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000045",
    "sentence": "推南北凡差視食甚人盈縮歷行定度，在周天象限已下爲初限，已上與半歲周相減爲末限。",
    "entities": [
      {
        "text": "半歲",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000046",
    "sentence": "以初末限自之，如一千八百七十度而一，得數，置四度四十六分減之，餘爲南北凡差。",
    "entities": [
      {
        "text": "一千八百七十度",
        "label": "NUM"
      },
      {
        "text": "四度",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000047",
    "sentence": "推南北定差置南北凡差，以距午定分乘之，如半晝分而一，以減凡差，餘爲南北定差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000048",
    "sentence": "若凡差數少，即反減之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000049",
    "sentence": "盈初縮末食在正交爲減，中交爲加。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000050",
    "sentence": "縮初盈末，食在正交爲加，中交爲減。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000051",
    "sentence": "如系凡差反減而得者，則其加減反是。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000052",
    "sentence": "推東西凡差置半歲周，減去食甚入盈縮歷行定度，餘食甚入盈縮歷行定度乘之，以一千八百七十除之爲度，即東西凡差。",
    "entities": [
      {
        "text": "半歲",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000053",
    "sentence": "推東西定差置東西凡差，以距午定分乘之，如二千五百度而一，視得數在東西凡差以下，即爲東西定差。",
    "entities": [
      {
        "text": "二千五百度",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000054",
    "sentence": "若在凡差已上，倍凡差減之，餘爲定差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000055",
    "sentence": "盈歷中前，縮歷後者，正交減，中交加。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000056",
    "sentence": "盈歷中後，縮中前者，正交加，中交減。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000057",
    "sentence": "推正交中定限度視日食在正交者置正交度，在中交者置中交度，以南北東西二定差加減之，即得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000058",
    "sentence": "推日食入陰陽曆去閃前後度視交定在正交定限度已下，減去交定度，餘爲陰曆交前度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000059",
    "sentence": "已上，減去正交定限度，餘爲陽曆交後度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000060",
    "sentence": "在中交定限度已下，減去交定度，餘爲陽曆閃前度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000061",
    "sentence": "已上，減去中交定限度，餘爲陰曆後度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000062",
    "sentence": "若交定在七度已下者加交終度，減去正交定限度，餘爲陽曆交後度。",
    "entities": [
      {
        "text": "七度",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000063",
    "sentence": "推日食分秒在陽曆者，置陽食限六度，減去陽曆交前、交後度，不及減者，不食。",
    "entities": [
      {
        "text": "六度",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000064",
    "sentence": "陰曆同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000065",
    "sentence": "餘以定法六十而一。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000066",
    "sentence": "在陰曆者，置陰食限八度，減去陰曆交前、交後度，餘以定法八十而一，即得。",
    "entities": [
      {
        "text": "八度",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000067",
    "sentence": "推定用分置日食分秒與二十分相減相乘，爲開方積。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000068",
    "sentence": "以平方法開之，爲開方數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000069",
    "sentence": "用五千七百四十分七因八百二十分也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000070",
    "sentence": "乘之，如定限行度而一，即得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000071",
    "sentence": "推初虧復圓時刻置食甚定分，以定用分減爲初虧，加爲復圓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000072",
    "sentence": "各依發斂加時，即時刻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000073",
    "sentence": "推日食起復方位陽曆初虧西南，甚於正南，復於東南。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000074",
    "sentence": "陰曆初虧西北，甚於正北，復於東北。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000075",
    "sentence": "若在八分以上，不分陰陽曆皆虧正西，復東位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000076",
    "sentence": "據午地而論推食甚日躔黃道宿次置食甚入盈縮歷行定度，在盈就爲定積度，在縮加半歲周爲定積度。",
    "entities": [
      {
        "text": "半歲",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000077",
    "sentence": "置定積度，以歲前冬至加時黃道日度加之，滿黃道積度鈐去之，至不滿宿次即食甚日躔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000078",
    "sentence": "推日帶食視初虧食甚分，有在日出分已下，爲晨刻帶食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000079",
    "sentence": "食甚復圓分，有在日入分已上，爲昏刻帶食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000080",
    "sentence": "在晨置日出分，在昏昏置日入分，皆以食甚分與之相減，餘爲帶食差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000081",
    "sentence": "置帶帶差，以日食分秒乘之，以定用分而一，所得減日食分秒，餘爲所見帶食分秒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000082",
    "sentence": "推交常度置望下入交凡分，乘月平行，如日食法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000083",
    "sentence": "推交定度置交常度，以望下盈縮差盈加縮減之即得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000084",
    "sentence": "不及減者，加交終度減之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000085",
    "sentence": "推食甚定分不用時差，即以定望分爲食甚分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000086",
    "sentence": "推食甚入盈縮歷行定度法同推日食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000087",
    "sentence": "推月食入陰陽曆視交定度在交中度已下爲陽曆，已上減去交中度，餘爲隊歷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000088",
    "sentence": "推交前交後度視所得入陰陽曆，在後準已下爲交後，在前準已上置交中度減之，餘爲交前。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000089",
    "sentence": "推月食分秒置月食限一十三度零五，減去前交後度，不及減者不食。",
    "entities": [
      {
        "text": "一十三度",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000090",
    "sentence": "餘以定法八十七分而一，即得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000091",
    "sentence": "推月食用分置三十分，與月食分秒相減相乘，爲開方積。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000092",
    "sentence": "依平方法開之，爲開方數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000093",
    "sentence": "又以四千九百二十乃六因八百二十分數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000094",
    "sentence": "分乘之，如定限行度而一，即得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000095",
    "sentence": "推月食三限初虧、食甚、復圓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000096",
    "sentence": "時刻置食甚分定分，以用分減爲初虧，加爲復圓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000097",
    "sentence": "依發斂得時刻如日食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000098",
    "sentence": "推月食五限時刻月食十分已上者，用五限推之，初虧、食既、食甚、生光、復圓也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000099",
    "sentence": "置月食分秒，減去十分，餘與十分相減相乘，爲開方積。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000100",
    "sentence": "平方開之，爲開方數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000101",
    "sentence": "又以四千九百二十分乘之，如定限行度而一爲既內分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000102",
    "sentence": "與定用分相減，餘爲既外分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000103",
    "sentence": "置食甚定分，減既內分爲既分，又減既外分爲初虧分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000104",
    "sentence": "再置食甚定分，加既內分爲生光分，又加既外分爲復圓分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000105",
    "sentence": "各依以斂得時刻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000106",
    "sentence": "推更點置晨分們之，五分之爲更法，又五分之爲點法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000107",
    "sentence": "推月食入更點各置三限或五限，在昏分已上減去昏分，在晨分已下加入晨分，不滿更法爲初更，不滿點法爲一點，以次求之，各得更點之數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000108",
    "sentence": "推月食起復方位陽曆初虧東北，甚於正北，復於西北。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000109",
    "sentence": "陰曆初虧東南，甚於正南，復於西南。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000110",
    "sentence": "若食在八分已上者，皆初虧正東，復於正西。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000111",
    "sentence": "推食甚月離黃道宿次置食甚入盈縮歷定度，在盈加半周天，在縮減去七十五秒爲定積度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000112",
    "sentence": "置定積度，加歲前冬至加時黃道日度，以黃道積度鈐去之，即得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000113",
    "sentence": "推月帶食視初虧、食甚、復圓等分，在日入分以下，爲昏刻帶食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000114",
    "sentence": "在日出分已上，爲晨刻帶食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000115",
    "sentence": "推法同日食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000116",
