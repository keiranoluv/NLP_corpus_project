    "sentence_id": "HCH_012_036_000158",
    "sentence": "推五星前後合置中積，加合應，滿周率去之，餘爲前合。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000159",
    "sentence": "再置周率，以前合減之，於爲後合。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000160",
    "sentence": "如滿歲周去之，即其年無後合分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000161",
    "sentence": "推五星中積日中星度置各星後合，既爲合伏下中積中星。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000162",
    "sentence": "命爲日，曰中積。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000163",
    "sentence": "命爲度，曰中星。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000164",
    "sentence": "累加段日，爲各段中積。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000165",
    "sentence": "皆滿歲周去之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000166",
    "sentence": "以各段下平度，累加各段下平度，滿歲周去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000167",
    "sentence": "退則減之，不及減，加歲周減之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000168",
    "sentence": "次復累加之，爲各段中星。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000169",
    "sentence": "推五星盈縮歷置中積，加歷應及生合，滿曆率去之，餘以度率而一爲度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000170",
    "sentence": "在歷中已下爲盈，已上減去歷中爲縮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000171",
    "sentence": "置各星合伏下盈縮歷，以段下限度累加之之滿歷中去之，盈交縮，縮交盈，即各段盈縮歷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000172",
    "sentence": "推五星盈縮差置各段盈縮歷，以歷策除之爲策數，不盡，爲策餘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000173",
    "sentence": "以其下損益分見立成。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000174",
    "sentence": "乘之，以歷策而一，所得益加損減其盈縮積分，即盈縮差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000175",
    "sentence": "金星倍之，水星三之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000176",
    "sentence": "推定積日置各段中積，以其段盈縮差盈加縮減之，即得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000177",
    "sentence": "滿歲周去之，如中積不及減者，加歲周減之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000178",
    "sentence": "本段原無差者，借前段差加之，則金水二星，亦只用所得盈縮差，不用三之倍之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000179",
    "sentence": "推加時定日置定積日，以歲前天正冬至分加之，滿紀法去之，餘命甲子算外，即爲定日。",
    "entities": [
      {
        "text": "甲子",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000180",
    "sentence": "視定積日會滿歲周去者，用本年冬至，會加歲周減者，用歲前冬至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000181",
    "sentence": "推所入月日置合伏下定積，以加天正閏餘滿朔策除之，爲月數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000182",
    "sentence": "起歲前十一月，其不滿朔策者，即入月已來日分也。",
    "entities": [
      {
        "text": "十一月",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000183",
    "sentence": "視其月定朔甲子，與加時定日甲子相去即合伏日，累加相距日，滿各月大小去之，即各段所入月日。",
    "entities": [
      {
        "text": "其月",
        "label": "TME"
      },
      {
        "text": "甲子",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000184",
    "sentence": "推定星置各段中星，依推定積日法，以盈縮差加減之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000185",
    "sentence": "推加時定星置定星，以歲前冬至加時黃道日度加之，滿週歲天去之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000186",
    "sentence": "若定積日會加歲周者，用歲前黃道日度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000187",
    "sentence": "遇減歲周者，用本年黃道目度，如原無中星度，段下亦無定星星及加時定星度分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000188",
    "sentence": "推加減定分置定日小余，以其段初行率乘之，滿萬爲分，所得諸段爲減分，退段爲加分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000189",
    "sentence": "推夜半定星及宿次置加時定星，以加減定分加減之，爲夜半定星。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000190",
    "sentence": "以黃道積度鈐減之，爲夜半宿次。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000191",
    "sentence": "其留段即用時定星，爲夜半一星。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000192",
    "sentence": "推日度率置各段定日，與次段定日相減爲日率。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000193",
    "sentence": "次段不及減，加紀法減之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000194",
    "sentence": "置各段夜半－定星，與次段夜半定星相減爲度漲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000195",
    "sentence": "次段不及減，加周天減之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000196",
    "sentence": "凡近留之段，皆用留段加時定星，與本段夜半定星相減。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000197",
    "sentence": "如星度逆者，以後段減前段，即各得度率。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000198",
    "sentence": "推平行分置度率，以日率除之，即得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000199",
    "sentence": "推凡差及增減總差日差以本段前後之平行分相減，爲本段凡差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000200",
    "sentence": "凡五星之伏段及近留之遲段及退段，皆無凡差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000201",
    "sentence": "倍凡差，退一位爲增減差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000202",
    "sentence": "倍增減差爲總差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000203",
    "sentence": "置總差，以日率減一日除之爲日差。",
    "entities": [
      {
        "text": "一日",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_036_000204",
    "sentence": "初日行分多，爲減差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000205",
    "sentence": "末日行分多，爲加差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000206",
    "sentence": "推初日行分末日行分以增減差加減其段平行分，爲初末日行分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000207",
    "sentence": "視本段平行分與次段平行分相較，前多後少者，加爲初，減爲末。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000208",
    "sentence": "前少後多者，減爲初，加爲末。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000209",
    "sentence": "推撫心差諸段爲增減差總差日差合伏者，置次段初日行分，加其日差之半，亦次段日差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000210",
    "sentence": "爲末日行分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000211",
    "sentence": "晨伏、夕伏者，置前段本段之前。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000212",
    "sentence": "末日行分，加其日差之半，亦前段日差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000213",
    "sentence": "爲二伏初日行分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000214",
    "sentence": "置伏段呼得初末日行分，皆與本段平行分相減，餘爲增減差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000215",
    "sentence": "又以增差加減平行分，爲初末日行分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000216",
    "sentence": "視合伏末日行全較平行分，少則加，多則減，爲初日行分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000217",
    "sentence": "晨伏、夕伏初日行分較平行分，亦少加多減，爲末日行分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000218",
    "sentence": "木、火之晨遲末，土之晨遲，金之夕遲末，水之夕遲，皆置其前末日行分，銳其日差減之，即前段日差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000219",
    "sentence": "餘爲初日行分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000220",
    "sentence": "木、火之夕遲初，土之夕遲，金之晨初，水之晨遲，皆置其後段初日行分，倍其日差減之，後段日差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000221",
    "sentence": "餘爲末日行分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000222",
    "sentence": "木、火、土之夕伏，金、水之晨伏，皆置其前段末日行分，內加其前段日差之半，爲鈦段初日行分，皆與平行分相減，餘爲增減差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000223",
    "sentence": "木、火之晨退、夕退，置其平行分，退一位、六因之，爲增減差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000224",
    "sentence": "晨退減爲初，加爲末。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000225",
    "sentence": "夕退加爲初，減爲末。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000226",
    "sentence": "晨加夕減，二段相比較。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000227",
    "sentence": "金之夕退伏合伏，置其平行分，退一位，三因之折半。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000228",
    "sentence": "水之夕退伏合退伏，以平行分折半，各爲增減差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000229",
    "sentence": "金之夕退，置其平分，退一位，三在之折半。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000230",
    "sentence": "水之夕退伏合退伏，以平行分折半，各爲增減差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000231",
    "sentence": "金之夕退，置其後段祿日行分，減日差，後段日差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000232",
    "sentence": "爲末日行分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000233",
    "sentence": "金之晨退，置其前段末日行分，減日差，前段日差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000234",
    "sentence": "爲初日行分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000235",
    "sentence": "皆與平行分相減，餘爲增減差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000236",
    "sentence": "凡增減差，倍之爲總差，以相距日率減一除之，爲日差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000237",
    "sentence": "其初末日行分有其一者，以增減差加減，更求其一，如伏段法，餘依前後平行分相較增減之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000238",
    "sentence": "金、火之夕遲末，晨遲初，置其段平行分，以相距日率下不倫分乘之，不倫分之秒，與平行之分對。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000239",
    "sentence": "即爲增減差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000240",
    "sentence": "置平行分，夕者以增減差，加爲初日行分，減爲末日行分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000241",
    "sentence": "晨者反是。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000242",
    "sentence": "不倫分金、火星之夕遲末，與晨遲初，其增減差，多於平行分者，爲不倫分也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000243",
    "sentence": "推五星每日細行，置各段夜半宿次，以初日行分順加退減之，爲次日宿次。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000244",
    "sentence": "又以日差加減其初日行分，爲每日行分，亦順加退減於次日宿次，滿黃道宿次去之，至次段宿次而止，爲每日夜半宿次。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000245",
    "sentence": "推五星順逆交宮時刻視逐日五星細行，與黃道十二宮界宿次同名，其度分又相近者以相減。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000246",
    "sentence": "視其餘分，在本日行分以下者，爲交宮在本日也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000247",
    "sentence": "順行者，以本日夜半星行宿次度分減宮界度分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000248",
    "sentence": "退行者，以宮界度分減本日夜半星行宿次度分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000249",
    "sentence": "扣以日周乘之爲實，以本日行分爲法，法除實，得數，依發斂加時法，得交宮時刻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000250",
    "sentence": "推五星伏見凡取伏見，伏者要在已下，見者要在已上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000251",
    "sentence": "晨見晨伏者，置其日太陽行度，內減各星行度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000252",
    "sentence": "夕見夕伏者，置其日各星行度，內減太陽行度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000253",
    "sentence": "即爲其日晨昏伏見度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000254",
    "sentence": "置本日伏見度，與次日伏見度相減，餘四而一，即得晨昏伏見分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000255",
    "sentence": "視本日伏見度較次日伏見度爲多者減，少者加。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000256",
    "sentence": "晨者，置本日伏見度，以伏見分加減之，爲晨伏見度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000257",
    "sentence": "夕者，三因伏見分，置伏見度加減之，爲夕伏見度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000258",
    "sentence": "視在各星伏見度上下取之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000259",
    "sentence": "紫氣週日一萬零二百二十七日一七九二。",
