  },
  {
    "sentence_id": "HCH_012_036_000019",
    "sentence": "▲陰食限視定望入交。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_036_000020",
    "sentence": "一日二零已下一十二日四零已上在零日一十三日，不問小余，皆入食限。",
    "entities": [
      {
