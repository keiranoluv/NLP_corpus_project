[
  {
    "sentence_id": "HCH_012_100_000000",
    "sentence": "明太祖建藩，子孫世系預錫嘉名，以示傳世久遠。",
    "entities": [
      {
        "text": "明太祖",
        "label": "TITLE"
      },
      {
        "text": "子孫",
        "label": "PER"
      },
      {
        "text": "嘉名",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_100_000001",
    "sentence": "當神宗中葉，僅及祖訓之半，而不億之麗，宗祿虧乏，議者遂有減歲祿，限宮媵，且限支子之請。",
    "entities": [
      {
        "text": "神宗",
        "label": "TITLE"
      },
      {
        "text": "祖訓",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_100_000002",
    "sentence": "由是支屬承祧者，親王無旁推之恩；群從繼世者，郡封絕再裂之例，以及名婚不時有明禁，本折互支屬常期。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_100_000003",
    "sentence": "啓、禎時，軍饷告絀，大農蒿目，安能顧瞻藩維。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_100_000004",
    "sentence": "親王或可自存，郡王以致中尉空乏尤甚。",
    "entities": [
      {
        "text": "親王",
        "label": "TITLE"
      },
      {
        "text": "郡王",
        "label": "TITLE"
      },
      {
        "text": "中尉",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_100_000005",
    "sentence": "一旦盜起，無力禦侮，徒手就戮，宗社爲墟，惜哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_100_000006",
    "sentence": "考之史冊，漢諸王表與王子侯離而不屬，世次難明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_100_000007",
    "sentence": "唐宗族蕃大，源遠流長，然諸王以不出閤，不分房，子孫皆闕而不著。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_100_000008",
    "sentence": "宋史於太祖、太宗、魏王廷美之裔，迄臨安淪沒，悉載譜牒，而賢愚並列，漫無裁割。",
    "entities": [
      {
        "text": "宋史",
        "label": "ORG"
      },
      {
        "text": "太祖",
        "label": "TITLE"
      },
      {
        "text": "太宗",
        "label": "TITLE"
      },
      {
        "text": "魏王",
        "label": "TITLE"
      },
      {
        "text": "廷美",
        "label": "PER"
      },
      {
        "text": "臨安",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_100_000009",
    "sentence": "茲表明代親王至郡王而止，以從史、漢諸王及王子侯之例。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_100_000010",
    "sentence": "又彷唐宗分房法，繫各府郡王於親王之下，如小宗之從大宗。",
    "entities": [
      {
        "text": "唐宗",
        "label": "ORG"
      },
      {
        "text": "郡王",
        "label": "TITLE"
      },
      {
        "text": "親王",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_100_000011",
    "sentence": "其餘不得封者，概不載。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_100_000012",
    "sentence": "太祖二十六子。",
    "entities": [
      {
        "text": "太祖",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_100_000013",
    "sentence": "懿文太子外，皇子楠未封。",
    "entities": [
      {
        "text": "懿文太子",
        "label": "TITLE"
      },
      {
        "text": "皇子",
        "label": "TITLE"
      },
      {
        "text": "楠",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_100_000014",
    "sentence": "成祖以洪武三年封燕王，後尊爲帝系，不得仍列之藩封世次。",
    "entities": [
      {
        "text": "成祖",
        "label": "TITLE"
      },
