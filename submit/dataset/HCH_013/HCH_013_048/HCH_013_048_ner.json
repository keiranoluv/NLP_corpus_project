  {
    "sentence_id": "HCH_013_048_000139",
    "sentence": "時諸縣民皆為大鬢所脇，三人者獨抗賊，賊讐之。",
    "entities": [
      {
        "text": "大鬢",
        "label": "PER"
      },
      {
        "text": "三人",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000140",
    "sentence": "守仁還兵，三人來告變，言大鬢反狀。",
    "entities": [
      {
        "text": "守仁",
        "label": "PER"
      },
      {
        "text": "三人",
        "label": "NUM"
      },
      {
        "text": "大鬢",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000141",
    "sentence": "時池仲安方領兵在守仁所，守仁乃佯怒三人，收縛，將斬之，曰：「大鬢方遣弟領兵報效，安得有此？」",
    "entities": [
      {
        "text": "池仲安",
        "label": "PER"
      },
      {
        "text": "守仁",
        "label": "PER"
      },
      {
        "text": "三人",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000142",
    "sentence": "仲安遂叩首辨列三人罪惡，守仁佯信之，械繫珂等，置之獄。",
    "entities": [
      {
        "text": "仲安",
        "label": "PER"
      },
      {
        "text": "三人",
        "label": "NUM"
      },
      {
        "text": "守仁",
        "label": "PER"
      },
      {
        "text": "珂",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000143",
    "sentence": "守仁密使人至獄中諭以意，令三人無恐，且遣使歸，集眾以候。",
    "entities": [
      {
        "text": "守仁",
        "label": "PER"
      },
      {
        "text": "獄",
        "label": "LOC"
      },
      {
        "text": "三人",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000144",
    "sentence": "十二月二十日，守仁還至贛，張樂大饗將士，下令橫水、桶岡既平，浰頭歸順，境內無虞矣。",
    "entities": [
      {
        "text": "十二月二十日",
        "label": "TME"
      },
      {
        "text": "守仁",
        "label": "PER"
