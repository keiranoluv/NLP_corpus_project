      {
        "text": "橫水",
        "label": "LOC"
      },
      {
        "text": "桶岡",
        "label": "LOC"
      },
      {
        "text": "浰頭",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000145",
    "sentence": "民久勞苦，宜休兵為樂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_048_000146",
    "sentence": "遂散兵使歸農，乃遣仲安歸報其兄，以盧珂被繫故，遣使令大鬢勿撤備，以防珂黨掩襲，大鬢意乃大安。",
    "entities": [
      {
        "text": "仲安",
        "label": "PER"
      },
      {
        "text": "盧珂",
        "label": "PER"
      },
      {
        "text": "大鬢",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000147",
    "sentence": "守仁別購仲安所親，說仲安令自來投訴，云：「官意良厚，何可不親一往謝？況使盧珂等言無所入。」",
    "entities": [
      {
        "text": "守仁",
        "label": "PER"
      },
      {
        "text": "仲安",
        "label": "PER"
      },
      {
        "text": "盧珂",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000148",
    "sentence": "大鬢信之，謂其下曰：「欲伸先屈，贛州伎倆，須自往觀之。」",
    "entities": [
      {
        "text": "大鬢",
        "label": "PER"
      },
      {
        "text": "贛州",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000149",
    "sentence": "遂帥其徒四十餘人自詣贛。",
    "entities": [
      {
        "text": "四十餘人",
        "label": "NUM"
      },
      {
        "text": "贛",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000150",
    "sentence": "守仁先已檄諸郡縣及龍川等，勒兵候報，至是探知大鬢就道，亟遣使發諸路兵候浰頭。",
    "entities": [
      {
        "text": "守仁",
        "label": "PER"
      },
      {
        "text": "龍川",
        "label": "LOC"
      },
      {
        "text": "浰頭",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000151",
    "sentence": "然道經賊巢始達，則使別齎一檄為捕盧珂黨與者，佯示賊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_048_000152",
    "sentence": "賊果問，見檄遂不為意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_048_000153",
    "sentence": "大鬢至贛，謁守仁，見軍門無用兵形，又覘知珂等繫獄，意益安，遣人歸報其黨，謂事無他。",
    "entities": [
      {
        "text": "大鬢",
        "label": "PER"
      },
      {
        "text": "贛",
        "label": "LOC"
      },
      {
        "text": "守仁",
        "label": "PER"
      },
      {
        "text": "軍門",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000154",
    "sentence": "守仁乃夜釋珂等，使間道歸發兵，而令諸官屬以次設牛酒，日宴犒大鬢等，緩其歸。",
    "entities": [
      {
        "text": "守仁",
        "label": "PER"
      },
      {
        "text": "珂",
        "label": "PER"
      },
      {
        "text": "大鬢",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000155",
    "sentence": "久之，度珂已至家，諸郡縣兵當大集，守仁乃設犒於庭，先伏甲士，引大鬢等入，悉擒之。",
    "entities": [
      {
        "text": "守仁",
        "label": "PER"
      },
      {
        "text": "大鬢",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000156",
    "sentence": "出珂狀訊之，皆服，遂悉置獄，而趣諸路同抵賊巢。",
    "entities": [
      {
        "text": "珂",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000157",
    "sentence": "守仁率親兵由龍南縣冷水徑直擣下浰大巢，諸路兵皆令入三浰。",
    "entities": [
      {
        "text": "守仁",
        "label": "PER"
      },
      {
        "text": "龍南縣",
        "label": "LOC"
      },
      {
        "text": "冷水",
        "label": "LOC"
      },
      {
        "text": "浰",
        "label": "LOC"
      },
      {
        "text": "三浰",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000158",
    "sentence": "賊弛備既久，驟聞官兵四集，驚懼，乃分投出禦，而悉其精銳千餘，據險設伏於龍子嶺。",
    "entities": [
      {
        "text": "龍子嶺",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000159",
    "sentence": "官軍為三衝，犄角進，指揮余恩首擊賊，戰良久，賊敗。",
    "entities": [
      {
        "text": "余恩",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000160",
    "sentence": "王受等追之，伏發被扼。",
    "entities": [
      {
        "text": "王受",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000161",
    "sentence": "適推官危壽兵至，鼓譟前衝之。",
    "entities": [
      {
        "text": "推官",
        "label": "TITLE"
      },
      {
        "text": "危壽",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000162",
    "sentence": "千戶孟俊率兵遶其後，賊大潰，遂克三浰大巢。",
    "entities": [
      {
        "text": "千戶",
        "label": "TITLE"
      },
      {
        "text": "孟俊",
        "label": "PER"
      },
      {
        "text": "三浰",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000163",
    "sentence": "餘賊精銳尚八百人，聚九連山。",
    "entities": [
      {
        "text": "八百人",
        "label": "NUM"
      },
      {
        "text": "九連山",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_048_000164",
    "sentence": "山四面險絕，惟一面得上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_048_000165",
    "sentence": "賊設礧石滾木拒之，官兵不敢近。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_048_000166",
    "sentence": "守仁乃令官兵衣賊衣，抵暮，詐為賊敗奔者上山。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_048_000167",
    "sentence": "賊見之，果相招呼，官兵乃得渡險，遂扼其路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_048_000168",
    "sentence": "賊覺，急禦，則大眾已闌入矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_048_000169",
    "sentence": "賊不支，乃退走潰出，官兵先四路設伏待之，擒斬略盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_048_000170",
    "sentence": "餘徒二百人慟哭請降，守仁納之。",
    "entities": [
