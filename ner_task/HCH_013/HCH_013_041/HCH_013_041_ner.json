      }
    ]
  },
  {
    "sentence_id": "HCH_013_041_000021",
    "sentence": "前有小山高數仞，如拱壁狀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_041_000022",
    "sentence": "山後悉築墻，高二丈五六尺。",
