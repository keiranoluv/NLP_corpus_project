      }
    ]
  },
  {
    "sentence_id": "HCH_013_053_000042",
    "sentence": "希儀察其部下千戶趙臣者，雅善璋，乃召臣問曰：「聞岑璋與猛有隙，吾欲遣說之，藉令破猛如何？」",
    "entities": [
      {
        "text": "希儀",
        "label": "PER"
      },
      {
        "text": "千戶",
        "label": "TITLE"
      },
      {
        "text": "趙臣",
        "label": "PER"
      },
      {
        "text": "岑璋",
        "label": "PER"
      },
      {
        "text": "猛",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_053_000043",
    "sentence": "臣曰：「璋多智善疑，直語之必不信，當以計說之。」",
    "entities": [
      {
        "text": "璋",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_053_000044",
    "sentence": "希儀曰：「計將安出？」",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000045",
    "sentence": "臣曰：「鎮安與歸順為世讎，督府往使人歸順，則鎮安疑；使人鎮安，則歸順疑。公今誠遣臣徵兵鎮安，臣迂道過璋，璋必詢故。臣為好，故以死泄漏其事，璋要領可得也。」",
    "entities": [
      {
        "text": "鎮安",
        "label": "LOC"
      },
      {
        "text": "歸順",
        "label": "LOC"
      },
      {
        "text": "督府",
        "label": "LOC"
      },
      {
        "text": "璋",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_053_000046",
    "sentence": "希儀曰：「善。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000047",
    "sentence": "乃遣臣往檄鎮安兵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000048",
    "sentence": "臣過璋，璋果喜，迓臣曰：「久不見故人，今肯念我來耶？」",
    "entities": [
      {
        "text": "璋",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_053_000049",
    "sentence": "臣默然，佯為不豫者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000050",
    "sentence": "璋曰：「趙君有嗔乎？」",
    "entities": [
      {
        "text": "璋",
        "label": "PER"
      },
      {
        "text": "趙君",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_053_000051",
    "sentence": "臣曰：「感故人厚意，久契闊，故迂道來，何嗔也！」",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000052",
    "sentence": "稍語，須臾，復歎息起，璋心疑之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000053",
    "sentence": "明日，璋置酒款臣，臣愈不豫，若有沈思者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000054",
    "sentence": "璋益疑，問故，曰：「軍門有意督我過耶？」",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000055",
    "sentence": "臣曰：「無之。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000056",
    "sentence": "璋曰：「鄰壤有所控訴，將逮勘耶？」",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000057",
    "sentence": "臣曰：「無之。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000058",
    "sentence": "璋挽臣臥內，跪叩之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000059",
    "sentence": "臣潸然泣下，璋亦泣曰：「璋死即死耳，君何祕不告我？」",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000060",
    "sentence": "臣乃曰：「託君肺腑，有急不敢不告。然今日非君死，即我死矣。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000061",
    "sentence": "璋驚曰：「何故？」",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000062",
    "sentence": "臣曰：「督府討田州，謂君猛婦翁，必黨猛，令我檄鎮安兵襲君。我不言，君死；我言，君必驟發，為自脫計，即我泄漏機事矣，必我死。奈何？」",
    "entities": [
      {
        "text": "督府",
        "label": "LOC"
      },
      {
        "text": "田州",
        "label": "LOC"
      },
      {
        "text": "猛",
        "label": "PER"
      },
      {
        "text": "鎮安",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_053_000063",
    "sentence": "璋頓首謝曰：「君實生我，君不言，我赤族不悟。猛取吾女讎視之，吾何暱焉。吾欲殺猛久矣，無間也。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000064",
    "sentence": "臣曰：「君心如是，盍自列督府，匪直免禍，功有藉也。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000065",
    "sentence": "璋遂強臣稱疾，留傳舍。",
    "entities": [
      {
        "text": "璋",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_053_000066",
    "sentence": "亟遣［人］馳詣希儀所告變，陳猛反狀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000067",
    "sentence": "恐連及，願擒猛自效。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000068",
    "sentence": "希儀許之，遂陽使［使］追臣返，以其事白鏌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000069",
    "sentence": "鏌喜，乃不備璋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000070",
    "sentence": "岑猛子邦彥，守工堯隘。",
