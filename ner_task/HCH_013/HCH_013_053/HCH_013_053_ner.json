    ]
  },
  {
    "sentence_id": "HCH_013_053_000024",
    "sentence": "猛兵大肆侵掠，所至民徒村落避之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000025",
    "sentence": "賊平，金疏猛功，稍遷指揮同知。",
    "entities": [
      {
        "text": "指揮同知",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_053_000026",
    "sentence": "猛冀復知府秩，授官不愜初意，遂怨望驕蹇。",
    "entities": [
      {
        "text": "猛",
        "label": "PER"
      },
      {
        "text": "知府",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_053_000027",
    "sentence": "督府使又不得曩者厚賂，多譖猛不法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000028",
    "sentence": "猛亦持兵力，淩轢鄰府日甚。",
