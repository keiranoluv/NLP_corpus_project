        "text": "工堯隘",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_053_000071",
    "sentence": "璋以姻故，遣兵千人助之，實為間。",
    "entities": [
      {
        "text": "璋",
        "label": "PER"
      },
      {
        "text": "千人",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_053_000072",
    "sentence": "邦彥欣然納之。",
    "entities": [
      {
        "text": "邦彥",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_053_000073",
    "sentence": "璋則遣報希儀曰：「已遣千人為內應矣。衣別有識，幸勿加戮。」",
    "entities": [
      {
        "text": "璋",
        "label": "PER"
      },
      {
        "text": "希儀",
        "label": "PER"
      },
      {
        "text": "千人",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_013_053_000074",
    "sentence": "希儀許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000075",
    "sentence": "及戰，歸順兵先呼敗惑眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_013_053_000076",
    "sentence": "田州兵驚潰。",
    "entities": []
  },
  {
