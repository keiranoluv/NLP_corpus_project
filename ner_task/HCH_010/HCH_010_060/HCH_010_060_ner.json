    "entities": []
  },
  {
    "sentence_id": "HCH_010_060_000057",
    "sentence": "至末年，累與金戰，番漢戰馬損十六七，雖增價數倍，竟無所買，乃冒法買官馬從軍。",
    "entities": [
      {
        "text": "番漢",
        "label": "PER"
