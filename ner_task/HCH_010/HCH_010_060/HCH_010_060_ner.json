        "text": "十六七",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_060_000058",
    "sentence": "諸羣牧私賣日多，畋獵亦不足用，遂為金所敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_060_000059",
    "sentence": "棄眾播遷，以訖于亡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_060_000060",
    "sentence": "松漠以北舊馬，皆為大石林牙所有。",
    "entities": [
      {
        "text": "松漠",
        "label": "LOC"
      },
      {
        "text": "大石",
