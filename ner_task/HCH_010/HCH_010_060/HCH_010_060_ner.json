      }
    ]
  },
  {
    "sentence_id": "HCH_010_060_000018",
    "sentence": "其煎取之制，歲出之額，不可得而詳矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_060_000019",
    "sentence": "坑冶，則自太祖始併室韋，其地產銅、鐵、金、銀，其人善作銅、鐵器。",
    "entities": [
      {
