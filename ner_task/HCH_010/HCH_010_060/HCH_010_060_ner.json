      }
    ]
  },
  {
    "sentence_id": "HCH_010_060_000027",
    "sentence": "自此以訖天祚，國家皆賴其利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_060_000028",
    "sentence": "鼓鑄之法，先代撒剌的為夷離菫，以土產多銅，始造錢幣。",
    "entities": [
      {
        "text": "撒剌的",
        "label": "PER"
      },
      {
        "text": "夷離菫",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_060_000029",
    "sentence": "太祖其子，襲而用之，遂致富強，以開帝業。",
    "entities": [
      {
        "text": "太祖",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_060_000030",
    "sentence": "太宗置五冶太師，以總四方錢鐵。",
    "entities": [
      {
        "text": "太宗",
        "label": "TITLE"
      },
      {
        "text": "五冶太師",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_060_000031",
    "sentence": "石敬瑭又獻沿邊所積錢，以備軍實。",
    "entities": [
      {
        "text": "石敬瑭",
        "label": "PER"
      },
      {
        "text": "沿邊",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_060_000032",
    "sentence": "景宗以舊錢不足於用，始鑄乾亨新錢，錢用流布。",
    "entities": [
      {
        "text": "景宗",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_060_000033",
    "sentence": "聖宗鑿大安山，取劉守光所藏錢，散諸五計司，兼鑄太平錢，新舊互用。",
    "entities": [
      {
        "text": "聖宗",
        "label": "TITLE"
      },
      {
        "text": "大安山",
        "label": "LOC"
