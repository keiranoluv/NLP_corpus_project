[
  {
    "sentence_id": "HCH_010_032_000001",
    "sentence": "《周官》土圭之法：日東，景夕多風；日北，景長多寒。",
    "entities": [
      {
        "text": "周",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_032_000002",
    "sentence": "天地之間，風氣異宜，人生其間，各適其便。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_032_000003",
    "sentence": "王者因三才而節制之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_032_000004",
    "sentence": "長城以南，多雨多暑，其人耕稼以食，桑麻以衣，宮室以居，城郭以治。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_032_000005",
    "sentence": "大漠之間，多寒多風，畜牧畋漁以食，皮毛以衣，轉徙隨時，車馬為家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_032_000006",
    "sentence": "此天時地利所以限南北也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_032_000007",
    "sentence": "遼國盡有大漠，浸包長城之境，因宜為治。",
    "entities": [
      {
        "text": "遼",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_032_000008",
    "sentence": "秋冬違寒，春夏避暑，隨水草就畋漁，歲以為常。",
    "entities": [
      {
        "text": "夏",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_032_000009",
    "sentence": "四時各有行在之所，謂之「捺缽」。",
    "entities": [
      {
        "text": "捺缽",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_032_000010",
    "sentence": "春捺缽：曰鴨子河濼。",
