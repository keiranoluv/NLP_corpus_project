[
  {
    "sentence_id": "HCH_010_103_000001",
    "sentence": "遼起松漠，太祖以兵經略方內，禮文之事固所未遑。",
    "entities": [
      {
        "text": "遼",
        "label": "ORG"
      },
      {
        "text": "太祖",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000002",
    "sentence": "及太宗入汴，取晉圖書、禮器而北，然後制度漸以修舉。",
    "entities": [
      {
        "text": "太宗",
        "label": "TITLE"
      },
      {
        "text": "晉",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000003",
    "sentence": "至景、聖間，則科目聿興，士有由下僚擢升侍從，骎驍崇儒之美。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000004",
    "sentence": "但其風氣剛勁，三面鄰敵，歲時以蒐浯為務，而典章文物，視古猶闕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000005",
    "sentence": "然二百年之業，非數君子為之綜理，則後世惡所考述哉？",
    "entities": [
      {
        "text": "然二百年",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000006",
    "sentence": "作《文學傳》。",
    "entities": [
      {
        "text": "文學傳",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000007",
    "sentence": "蕭韓家奴，字休堅，涅剌部人，中書令安摶之孫。",
    "entities": [
      {
        "text": "蕭韓家奴",
        "label": "PER"
      },
      {
        "text": "涅剌部",
        "label": "ORG"
      },
      {
        "text": "中書令",
        "label": "TITLE"
      },
      {
        "text": "安摶",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000008",
    "sentence": "少好學，弱冠入南山讀書，博覽經史，通遼、漢文字。",
    "entities": [
      {
        "text": "遼",
        "label": "ORG"
      },
      {
        "text": "漢",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000009",
    "sentence": "統和十四年始仕。",
    "entities": [
      {
        "text": "統和十四年",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000010",
    "sentence": "家有一牛，不任驅策，其奴得善價鬻之。",
    "entities": [
      {
        "text": "一牛",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000011",
    "sentence": "韓家奴曰：「利己誤人，非吾所欲。」",
    "entities": [
      {
        "text": "韓家奴",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000012",
    "sentence": "乃歸直取牛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000013",
    "sentence": "二十八年，為右通進，典南京栗園。",
    "entities": [
      {
        "text": "二十八年",
        "label": "TME"
      },
      {
        "text": "右通進",
        "label": "TITLE"
      },
      {
        "text": "南京",
        "label": "LOC"
      },
      {
        "text": "栗園",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000014",
    "sentence": "重熙初，同知三司使事。",
    "entities": [
      {
        "text": "三司使",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000015",
    "sentence": "四年，遷天成軍節度使，徙彰湣宮使。",
    "entities": [
      {
        "text": "四年",
        "label": "TME"
      },
      {
        "text": "天成軍節度使",
        "label": "TITLE"
      },
      {
        "text": "彰湣宮使",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000016",
    "sentence": "帝與語，才之，命為詩友。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000017",
    "sentence": "嘗從容問曰：「卿居外有異聞乎？」",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000018",
    "sentence": "韓家奴對曰：「臣惟知炒栗：小者熟，則大者必生；大者熟，則小者必焦。使大小均熟，始為盡美。不知其他。」",
    "entities": [
      {
        "text": "韓家奴",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000019",
    "sentence": "蓋嘗掌栗園，故托栗以諷諫。",
    "entities": [
      {
        "text": "栗園",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000020",
    "sentence": "帝大笑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000021",
    "sentence": "詔作《四時逸樂賦》，帝稱善。",
    "entities": [
      {
        "text": "《四時逸樂賦》",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000022",
    "sentence": "時詔天下言治道之要，制問：「徭役不加於舊，征伐亦不常有，年谷既登，帑廩既實，而民重困，豈為吏者慢、為民者惰歟？今之徭役何者最重？何者尤苦？何所蠲省則為便益？補役之法何可以復？盜賊之害何可以止？」",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000023",
    "sentence": "韓家奴對曰：臣伏見比年以來，高麗未賓，阻卜猶強，戰守之備，誠不容已。",
    "entities": [
      {
        "text": "韓家奴",
        "label": "PER"
      },
      {
        "text": "高麗",
        "label": "ORG"
      },
      {
        "text": "阻卜",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000024",
    "sentence": "乃者選富民防邊，自備糧糗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000025",
    "sentence": "道路修阻，動淹歲月；比至屯所，費已過半；只牛單轂，鮮有還者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000026",
    "sentence": "其無丁之家，倍直傭僦，人憚其勞，半途亡竄，故戍卒之食多不能給。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000027",
    "sentence": "求假於人，則十倍其息，至有鬻子割田不能償者。",
    "entities": [
      {
        "text": "十倍",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000028",
    "sentence": "或逋役不歸，在軍物故，則復補以少壯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000029",
    "sentence": "其鴨淥江之東，戍役大率如此。",
    "entities": [
      {
        "text": "鴨淥江",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000030",
    "sentence": "況渤海、女直、高麗合從連衡，不時征討。",
    "entities": [
      {
        "text": "渤海",
        "label": "ORG"
      },
      {
        "text": "女直",
        "label": "ORG"
      },
      {
        "text": "高麗",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000031",
    "sentence": "富者從軍，貧者偵候。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000032",
    "sentence": "加之水旱，菽粟不登，民以日困。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000033",
    "sentence": "蓋勢使之然也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000034",
    "sentence": "方今最重之役，無過西戍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000035",
    "sentence": "如無西戍，雖遇凶年，困弊不至於此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000036",
    "sentence": "若能徙西戍稍近，則往來不勞，民無深患。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000037",
    "sentence": "議者謂徙之非便：一則損威名，二則召侵侮，三則棄耕牧之地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000038",
    "sentence": "臣謂不然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000039",
    "sentence": "阻卜諸部，自來有之。",
    "entities": [
      {
        "text": "阻卜",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000040",
    "sentence": "曩時北至臚朐河，南至邊境，人多散居，無所統壹，惟往來抄掠。",
    "entities": [
      {
        "text": "臚朐河",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000041",
    "sentence": "及太祖西征，至於流沙，阻卜望風悉降，西域諸國皆願入貢。",
    "entities": [
      {
        "text": "太祖",
        "label": "TITLE"
      },
      {
        "text": "流沙",
        "label": "LOC"
      },
      {
        "text": "阻卜",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000042",
    "sentence": "因遷種落，內置三部，以益吾國，不營城邑，不置戍兵，阻卜累世不敢為寇。",
    "entities": [
      {
        "text": "三部",
        "label": "NUM"
      },
      {
        "text": "阻卜",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000043",
    "sentence": "統和間，王太妃出師西域，拓土既遠，降附亦眾。",
    "entities": [
      {
        "text": "王太妃",
        "label": "TITLE"
      },
      {
        "text": "西域",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000044",
    "sentence": "自後一部或叛，鄰部討之，使同力相制，正得馭遠人之道。",
    "entities": [
      {
        "text": "一部",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000045",
    "sentence": "及城可敦，開境數千里，西北之民，徭役日增，生業日殫。",
    "entities": [
      {
        "text": "城可敦",
        "label": "LOC"
      },
      {
        "text": "數千里",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000046",
    "sentence": "警急既不能救，叛服亦復不恒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000047",
    "sentence": "空有廣地之名，而無得地之實。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000048",
    "sentence": "若貪土不已，漸至虛耗，其患有不勝言者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000049",
    "sentence": "況邊情不可深信，亦不可頓絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000050",
    "sentence": "得不為益，舍不為損。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000051",
    "sentence": "國家大敵，惟在南方。",
    "entities": [
      {
        "text": "國家",
        "label": "ORG"
      },
      {
        "text": "南方",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000052",
    "sentence": "今雖連和，難保他日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000053",
    "sentence": "若南方有變，屯戍遼邈，卒難赴援。",
    "entities": [
      {
        "text": "遼",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000054",
    "sentence": "我進則敵退，我還則敵來，不可不慮也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000055",
    "sentence": "方今太平已久，正可恩結諸部，釋罪而歸地，內徙戍兵以增堡障，外明約束以正疆界。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000056",
    "sentence": "每部各置酋長，歲修職貢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000057",
    "sentence": "叛則討之，服則撫之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000058",
    "sentence": "諸部既安，必不生釁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000059",
    "sentence": "如是，則臣雖不能保其久而無變，知其必不深入侵掠也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000060",
    "sentence": "或云棄地則損威，殊不知殫費竭財，以貪無用之地，使彼小部抗衡大國，萬一有敗，損威豈淺？",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000061",
    "sentence": "或又云，沃壤不可遽棄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000062",
    "sentence": "臣以為土雖沃，民不能久居，一旦敵來，則不免內徙，豈可指為吾土而惜之？",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000063",
    "sentence": "夫帑廩雖隨部而有，此特周急部民，一偏之惠，不能均濟天下。",
    "entities": [
      {
        "text": "周",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000064",
    "sentence": "如欲均濟天下，則當知民困之由，而窒其隙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000065",
    "sentence": "節盤遊，簡驛傳，薄賦斂，戒奢侈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000066",
    "sentence": "期以數年，則困者可蘇，貧者可富矣。",
    "entities": [
      {
        "text": "期以數年",
        "label": "TME"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000067",
    "sentence": "蓋民者國之本，兵者國之衛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000068",
    "sentence": "兵不調則曠軍役，調之則損國本。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000069",
    "sentence": "且諸部皆有補役之法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000070",
    "sentence": "昔補役始行，居者行者，類皆富實，故累世從戍，易為更代。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000071",
    "sentence": "近歲邊虞數起，民多匱乏，既不任役事，隨補隨缺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000072",
    "sentence": "茍無上戶，則中戶當之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000073",
    "sentence": "曠日彌年，其窮益甚，所以取代為艱也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000074",
    "sentence": "非惟補役如此，在邊戍兵亦然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000075",
    "sentence": "譬如一抔之土，豈能填尋丈之壑！",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000076",
    "sentence": "欲為長久之便，莫若使遠戍疲兵還於故鄉，薄其徭役，使人人給足，則補役之道可以復故也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000077",
    "sentence": "臣又聞，自昔有國家者，不能無盜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000078",
    "sentence": "比年以來，群黎雕弊，利於剽竊，良民往往化為凶暴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000079",
    "sentence": "甚者殺人無忌，至有亡命山澤，基亂首禍。",
    "entities": [
      {
        "text": "有亡命山",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000080",
    "sentence": "所謂民以困窮，皆為盜賊者，誠如聖慮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000081",
    "sentence": "今欲芟夷本根，願陛下輕徭省役，使民務農。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000082",
    "sentence": "衣食既足，安習教化，而重犯法，則民趨禮義，刑罰罕用矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000083",
    "sentence": "臣聞唐太宗問群臣治盜之方，皆曰：「嚴刑峻法。」",
    "entities": [
      {
        "text": "唐太宗",
        "label": "TITLE"
      },
      {
        "text": "治盜",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000084",
    "sentence": "太宗笑曰：「寇盜所以滋者，由賦斂無度，民不聊生。今朕內省嗜欲，外罷遊幸，使海內安靜，則寇盜自止。」",
    "entities": [
      {
        "text": "太宗",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_103_000085",
    "sentence": "由此觀之，寇盜多寡，皆由衣食豐儉，徭役重輕耳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_103_000086",
