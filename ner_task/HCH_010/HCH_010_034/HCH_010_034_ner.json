      {
        "text": "五人",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_034_000055",
    "sentence": "其南伐點兵，多在幽州北千里鴛鴦泊。",
    "entities": [
      {
        "text": "幽州",
        "label": "LOC"
      },
      {
        "text": "千里",
        "label": "NUM"
      },
      {
