        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_034_000061",
    "sentence": "既入南界，分為三路，廣信軍、雄州、霸州各一。",
    "entities": [
      {
        "text": "三路",
        "label": "NUM"
      },
      {
        "text": "廣信軍",
        "label": "LOC"
      },
      {
        "text": "雄州",
        "label": "LOC"
      },
      {
        "text": "霸州",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_034_000062",
    "sentence": "駕必由中道，兵馬都統、護駕等軍皆從。",
    "entities": [
      {
        "text": "中道",
        "label": "LOC"
      },
      {
        "text": "兵馬都統",
        "label": "TITLE"
      },
      {
        "text": "護駕",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_034_000063",
    "sentence": "各路軍馬遇縣鎮，即時攻擊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_034_000064",
    "sentence": "若大州軍，必先料其虛實、可攻次第而後進兵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_034_000065",
    "sentence": "沿途民居，園囿、桑柘，必夷伐焚蕩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_034_000066",
    "sentence": "至宋北京，三路兵皆會，以議攻取。",
    "entities": [
      {
        "text": "宋北京",
        "label": "LOC"
      },
      {
        "text": "三路",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_034_000067",
    "sentence": "及退亦然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_034_000068",
    "sentence": "三路軍馬前後左右有先鋒。",
    "entities": [
      {
        "text": "三路軍馬",
        "label": "LOC"
      },
      {
        "text": "先鋒",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_034_000069",
    "sentence": "遠探欄子馬各十數人，在先鋒前後二十餘里，全副衣甲，夜中每行十里或五里少駐，下馬側聽無有人馬之聲。",
    "entities": [
      {
        "text": "十數人",
        "label": "NUM"
      },
      {
        "text": "二十餘里",
        "label": "NUM"
      },
      {
        "text": "十里",
        "label": "NUM"
      },
      {
        "text": "五里",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_034_000070",
    "sentence": "有則擒之；力不可敵，飛報先鋒，齊力攻擊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_034_000071",
    "sentence": "如有大軍，走報主帥。",
    "entities": [
      {
        "text": "走報",
        "label": "TITLE"
      },
      {
        "text": "主帥",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_034_000072",
    "sentence": "敵中虛實，動必知之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_034_000073",
    "sentence": "軍行當道州城，防守堅固，不可攻擊，引兵過之。",
    "entities": [
      {
        "text": "州城",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_034_000074",
    "sentence": "恐敵人出城邀阻，乃圍射鼓噪，詐為攻擊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_034_000075",
    "sentence": "敵方閉城固守，前路無阻，引兵進，分兵抄截，使隨處州城隔絕不通，孤立無援。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_034_000076",
    "sentence": "所過大小州城，至夜，恐城中出兵突擊，及與鄰州計會軍馬，甲夜，每城以騎兵百人去城門左右百餘步，被甲執兵，立馬以待。",
    "entities": [
      {
        "text": "州城",
        "label": "LOC"
      },
      {
        "text": "城中",
        "label": "LOC"
      },
      {
        "text": "鄰州",
        "label": "LOC"
      },
      {
