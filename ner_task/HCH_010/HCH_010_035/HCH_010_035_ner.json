[
  {
    "sentence_id": "HCH_010_035_000001",
    "sentence": "漢武帝多行幸之事，置期門、佽飛、羽林之目，天子始有親軍。",
    "entities": [
      {
        "text": "漢武帝",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_035_000002",
    "sentence": "唐太宗加親、勛、翊、千牛之衛，布腹心之地，防衛密矣。",
    "entities": [
      {
        "text": "唐太宗",
        "label": "TITLE"
      },
      {
        "text": "千牛",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_035_000003",
    "sentence": "遼太祖宗室盛強，分叠剌部為二，宮衛內虛，經營四方，未遑鳩集。",
    "entities": [
      {
        "text": "遼太祖",
        "label": "TITLE"
      },
      {
        "text": "宗室",
        "label": "ORG"
      },
      {
        "text": "叠剌部",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_035_000004",
    "sentence": "皇后述律氏居守之際，摘蕃漢精銳為屬珊軍。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE"
      },
      {
        "text": "述律氏",
        "label": "ORG"
      },
      {
        "text": "漢",
        "label": "ORG"
      },
      {
        "text": "屬珊軍",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_035_000005",
    "sentence": "太宗益選天下精甲，置諸爪牙為皮室軍。",
    "entities": [
      {
        "text": "太宗",
        "label": "TITLE"
      },
      {
        "text": "皮室軍",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_035_000006",
    "sentence": "合騎五十萬，國威壯矣。",
    "entities": [
      {
        "text": "五十萬",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_035_000007",
    "sentence": "大帳皮室軍：太宗置，凡三十萬騎。",
    "entities": [
      {
        "text": "大帳皮室軍",
        "label": "LOC"
      },
      {
        "text": "太宗",
        "label": "TITLE"
      },
      {
        "text": "三十萬騎",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_035_000008",
    "sentence": "屬珊軍：地皇后屬，二十萬騎。",
    "entities": [
      {
        "text": "珊軍",
        "label": "LOC"
      },
      {
        "text": "地皇后",
        "label": "TITLE"
      },
      {
        "text": "二十萬騎",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_035_000009",
    "sentence": "宮衛騎軍太祖以叠剌部受禪，分本部為五院、六院，統以皇族，而親衛缺然。",
    "entities": [
      {
        "text": "太祖",
        "label": "TITLE"
      },
      {
        "text": "叠剌部",
        "label": "ORG"
      },
      {
        "text": "五院",
        "label": "LOC"
      },
      {
        "text": "六院",
        "label": "LOC"
      },
      {
        "text": "皇族",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_035_000010",
    "sentence": "乃立斡魯朵法，裂州縣，割戶丁，以強幹弱支。",
    "entities": [
      {
        "text": "斡魯朵",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_035_000011",
    "sentence": "詒謀嗣績，世建宮衛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_035_000012",
    "sentence": "入則居守，出則扈從，葬則因以守陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_035_000013",
    "sentence": "有兵事，則五京、二州各提轄司傳檄而集，不待調發州縣、部族，十萬騎軍已立具矣。",
    "entities": [
      {
        "text": "五京",
        "label": "NUM"
      },
      {
        "text": "二州",
        "label": "NUM"
      },
      {
        "text": "十萬騎軍",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_010_035_000014",
    "sentence": "恩意親洽，兵甲犀利，教練完習。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_035_000015",
    "sentence": "簡天下精銳，聚之腹心之中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_035_000016",
    "sentence": "懷舊者歲深，增新者世盛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_010_035_000017",
    "sentence": "此軍制之良者也。",
    "entities": []
  },
