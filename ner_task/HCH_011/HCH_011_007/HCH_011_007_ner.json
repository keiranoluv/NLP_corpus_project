[
  {
    "sentence_id": "HCH_011_007_000001",
    "sentence": "《易》曰：「有天地然後有萬物，有萬物然後有男女，有男女然後有夫婦。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_007_000002",
    "sentence": "夫婦之義尚矣哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_007_000003",
    "sentence": "周禮，王者立后六宮，三夫人、九嬪、二十七世婦、八十一御妻，以聽天下之內治。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_007_000004",
    "sentence": "故《昏義》云：「天子之與后，猶日之與月，陰之與陽，相須而成者也。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_007_000005",
    "sentence": "漢初因秦稱號，帝母稱皇太后，后稱皇后，而加以美人、良人、八子、七子之屬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_007_000006",
    "sentence": "至孝武制婕妤之徒凡十四等。",
    "entities": [
      {
        "text": "孝武",
        "label": "TITLE"
      },
      {
        "text": "婕妤",
        "label": "TITLE"
      },
      {
        "text": "十四",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_011_007_000007",
    "sentence": "降及魏、晉，母后之號，皆因漢法；自夫人以下，世有增損焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_007_000008",
    "sentence": "高祖撥亂反正，深鑒奢逸，惡衣菲食，務先節儉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_007_000009",
    "sentence": "配德早終，長秋曠位，嬪嬙之數，無所改作。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_007_000010",
    "sentence": "太宗、世祖出自儲藩，而妃並先殂，又不建椒閫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_007_000011",
    "sentence": "今之撰錄，止備闕云。",
    "entities": []
  },
  {
    "sentence_id": "HCH_011_007_000012",
    "sentence": "太祖獻皇后張氏，諱尚柔，范陽方城人也。",
