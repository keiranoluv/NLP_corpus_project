[
  {
    "sentence_id": "HCH_009_045_000001",
    "sentence": "昔者先王因人之知畏而作刑，因人之知恥而作法。",
    "entities": [
      {
        "text": "王",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000002",
    "sentence": "畏也、恥也，五性之良知，七情之大閑也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_045_000003",
    "sentence": "是故，刑以治已然，法以禁未然，畏以處小人，恥以遇君子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_045_000004",
    "sentence": "君子知恥，小人知畏，天下平矣！",
    "entities": [
      {
        "text": "君子",
        "label": "PER"
      },
      {
        "text": "小人",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000005",
    "sentence": "是故先王養其威而用之，畏可以教愛。",
    "entities": [
      {
        "text": "先王",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000006",
    "sentence": "慎其法而行之，恥可以立廉。",
    "entities": [
      {
        "text": "慎其法",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000007",
    "sentence": "愛以興仁，廉以興義，仁義興，刑法不幾於措乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_045_000008",
    "sentence": "金初，法制簡易，無輕重貴賤之別，刑、贖並行，此可施諸新國，非經世久遠之規也。",
    "entities": [
      {
        "text": "金",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000009",
    "sentence": "天會以來，漸從吏議，皇統頒制，兼用古律。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_045_000010",
    "sentence": "厥後，正隆又有《續降制書》。",
    "entities": [
      {
        "text": "《續降制書》",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000011",
    "sentence": "大定有《權宜條理》，有《重修制條》。",
    "entities": [
      {
        "text": "《權宜條理》",
        "label": "ORG"
      },
      {
        "text": "《重修制條》",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000012",
    "sentence": "明昌之世，《律義》、《敕條》並修，品式當浸備。",
    "entities": [
      {
        "text": "《律義》",
        "label": "TITLE"
      },
      {
        "text": "《敕條》",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000013",
    "sentence": "既而《泰和律義》成書，宜無遺憾。",
    "entities": [
      {
        "text": "泰和律義",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000014",
    "sentence": "然國脈紓蹙，風俗醇樗，世道升降，君子觀一代之刑法，每有以先知焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_045_000015",
    "sentence": "金法以杖折徒，累及二百，州縣立威，甚者置刃於杖，虐於肉刑。",
    "entities": [
      {
        "text": "金法",
        "label": "ORG"
      },
      {
        "text": "杖折徒",
        "label": "TITLE"
      },
      {
        "text": "二百",
        "label": "NUM"
      },
      {
        "text": "州縣",
        "label": "LOC"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000016",
    "sentence": "季年，君臣好用筐篋故習，由是以深文傅致為能吏，以慘酷辦事為長才。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_045_000017",
    "sentence": "百司奸贓真犯，此可決也，而微過亦然。",
    "entities": [
      {
        "text": "百司",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000018",
    "sentence": "風紀之臣，失糾皆決。",
    "entities": [
      {
        "text": "風紀之臣",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000019",
    "sentence": "考滿，校其受決多寡以為殿最。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_045_000020",
    "sentence": "原其立法初意，欲以同疏戚、壹小大，使之咸就繩約於律令之中，莫不齊手並足以聽公上之所為，蓋秦人強主威之意也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_045_000021",
    "sentence": "是以待宗室少恩，待大夫士少禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_045_000022",
    "sentence": "終金之代，忍恥以就功名，雖一時名士有所不免。",
    "entities": [
      {
        "text": "金",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000023",
    "sentence": "至於避辱遠引，罕聞其人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_045_000024",
    "sentence": "殊不知君子無恥而犯義，則小人無畏而犯刑矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_045_000025",
    "sentence": "是故論者於教愛立廉之道，往往致太息之意焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_045_000026",
    "sentence": "雖然，世宗臨御，法司奏讞，或去律援經，或揆義制法。",
    "entities": [
      {
        "text": "世宗",
        "label": "TITLE"
      },
      {
        "text": "法司",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000027",
    "sentence": "近古人君聽斷，言幾於道，鮮有及之者。",
    "entities": [
      {
        "text": "近古人君",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000028",
    "sentence": "章宗、宣宗嘗親民事，當寧裁決，寬猛出入雖時或過中，跡其矜恕之多，猶有祖風焉。",
    "entities": [
      {
        "text": "章宗",
        "label": "TITLE"
      },
      {
        "text": "宣宗",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000029",
    "sentence": "簡牘所存，可為高抬貴手者，《本紀》、《刑志》詳略互見云。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_045_000030",
    "sentence": "金國舊俗，輕罪笞以柳篸，殺人及盜劫者，擊其腦殺之，沒其家貲，以十之四入官，其六償主，並以家人為奴婢。",
    "entities": [
      {
        "text": "金國",
        "label": "ORG"
      },
      {
        "text": "十之四",
        "label": "NUM"
      },
      {
        "text": "六",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000031",
    "sentence": "其親屬欲以馬牛雜物贖者從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_045_000032",
    "sentence": "或重罪亦聽自贖，然恐無辨于齊民，則劓、刵以為別。",
    "entities": [
      {
        "text": "齊民",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000033",
    "sentence": "其獄則掘地深廣數丈為之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_045_000034",
    "sentence": "太宗雖承太祖無變舊風之訓，亦稍用遼、宋法。",
    "entities": [
      {
        "text": "太宗",
        "label": "TITLE"
      },
      {
        "text": "太祖",
        "label": "TITLE"
      },
      {
        "text": "遼",
        "label": "ORG"
      },
      {
        "text": "宋",
        "label": "ORG"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000035",
    "sentence": "天會七年，詔凡竊盜，但得物徒三年，十貫以上徒五年，刺字充下軍，三十貫以上終身，仍以贓滿盡命刺字於面，五十貫以上死，征償如舊制。",
    "entities": [
      {
        "text": "天會七年",
        "label": "TME"
      },
      {
        "text": "但得物徒三年",
        "label": "TME"
      },
      {
        "text": "十貫以上徒五年",
        "label": "TME"
      },
      {
        "text": "三十貫",
        "label": "NUM"
      },
      {
        "text": "五十貫",
        "label": "NUM"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000036",
    "sentence": "熙宗天眷元年十月，禁親王以下佩刀入宮。",
    "entities": [
      {
        "text": "熙宗",
        "label": "TITLE"
