      {
        "text": "十月",
        "label": "TME"
      },
      {
        "text": "親王",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000037",
    "sentence": "衛禁之法，實自此始。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_045_000038",
    "sentence": "三年，復取河南地，乃詔其民，約所用刑法皆從律文，罷獄卒酷毒刑具，以從寬恕。",
    "entities": [
      {
        "text": "三年",
        "label": "TME"
      },
      {
        "text": "河南地",
        "label": "PER"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000039",
    "sentence": "至皇統間，詔諸臣，以本朝舊制，兼采隋、唐之制，參遼、宋之法。",
    "entities": [
      {
        "text": "隋",
