      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000040",
    "sentence": "類以成書，名曰《皇統制》，頒行中外。",
    "entities": [
      {
        "text": "《皇統制》",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_009_045_000041",
    "sentence": "時制，杖罪至百，則臀、背分決。",
    "entities": []
  },
  {
    "sentence_id": "HCH_009_045_000042",
    "sentence": "及海陵庶人以脊近心腹，遂禁之，雖主決奴牌，亦論以違制。",
    "entities": [
      {
        "text": "海陵庶人",
