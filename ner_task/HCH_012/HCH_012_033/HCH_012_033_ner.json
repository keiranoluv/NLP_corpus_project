    "entities": []
  },
  {
    "sentence_id": "HCH_012_033_000046",
    "sentence": "置各段限平差，與後段相減爲一差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_033_000047",
    "sentence": "置一差，與後段一差相減爲二差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_033_000048",
    "sentence": "置第一段限平差一十零分七二六爲凡平積。",
