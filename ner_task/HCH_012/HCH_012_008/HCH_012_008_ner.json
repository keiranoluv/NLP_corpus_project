      }
    ]
  },
  {
    "sentence_id": "HCH_012_008_000003",
    "sentence": "幼端重沉靜，言動有經。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_008_000004",
    "sentence": "稍長習射，發無不中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_008_000005",
    "sentence": "好學問，從儒臣講論不輟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_008_000006",
