      {
        "text": "太祖",
        "label": "TITLE"
      }
    ]
  },
  {
    "sentence_id": "HCH_012_008_000013",
    "sentence": "對曰：「不敢忽，顧小過不足瀆天聽。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_008_000014",
    "sentence": "又嘗問：「堯、湯時水旱，百姓奚恃？」",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_008_000015",
    "sentence": "對曰：「恃聖人有恤民之政。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_012_008_000016",
    "sentence": "太祖喜曰：「孫有君人之識矣。」",
